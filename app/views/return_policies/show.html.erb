<%= render "shared/page_header",
      title: @return_policy.name,
      breadcrumbs: [ { label: "Return policies", path: return_policies_path }, { label: @return_policy.name } ],
      actions: capture {
        if Current.user.can?("classification.return_policy.manage", store: Current.store)
          concat link_to("Edit", edit_return_policy_path(@return_policy), class: "button button-primary")
        end
        concat link_to("Back to return policies", return_policies_path, class: "button button-outline")
      } %>

<section class="record-section">
  <h2>Details</h2>
  <%= render "shared/record_summary", rows: [
    [ "Code", tag.code(@return_policy.code) ],
    [ "Name", @return_policy.name ],
    [ "Final sale", @return_policy.final_sale? ? "Yes" : "No" ],
    [ "Return window (days)", @return_policy.return_window_days || "—" ],
    [ "Status", boolean_status(@return_policy.active?) ]
  ] %>
</section>
