<%= form_with model: return_policy do |form| %>
  <% if return_policy.errors.any? %>
    <ul>
      <% return_policy.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  <% end %>
  <% if return_policy.persisted? %>
    <div><%= form.label :code %> <%= return_policy.code %></div>
  <% else %>
    <div><%= form.label :code %> <%= form.text_field :code %></div>
  <% end %>
  <div><%= form.label :name %> <%= form.text_field :name %></div>
  <div><%= form.label :final_sale %> <%= form.check_box :final_sale %></div>
  <div><%= form.label :return_window_days %> <%= form.number_field :return_window_days %></div>
  <div><%= form.label :active %> <%= form.check_box :active %></div>
  <div><%= form.submit %></div>
<% end %>
