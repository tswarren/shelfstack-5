<%= form_with model: return_policy, class: "form" do |form| %>
  <%= render "shared/form_errors", object: return_policy %>

  <section class="form-section">
    <h2 class="form-section-title">Details</h2>
    <div class="form-grid">
      <div class="field">
        <%= form.label :code, class: "field-label" %>
        <% if return_policy.persisted? %>
          <%= form.text_field :code, class: "input input-code", disabled: true %>
        <% else %>
          <%= form.text_field :code, class: "input input-code" %>
        <% end %>
      </div>
      <div class="field">
        <%= form.label :name, class: "field-label" %>
        <%= form.text_field :name, class: "input" %>
      </div>
      <div class="field">
        <%= form.label :return_window_days, class: "field-label" %>
        <%= form.number_field :return_window_days, class: "input", min: 0 %>
        <p class="field-hint">Number of days a return is accepted. Leave blank if not time-limited.</p>
      </div>
    </div>
    <div class="checkbox-group">
      <label><%= form.check_box :final_sale %> Final sale (no returns)</label>
      <label><%= form.check_box :active %> Return policy is active</label>
    </div>
  </section>

  <div class="form-actions">
    <%= form.submit return_policy.persisted? ? "Update return policy" : "Create return policy", class: "button button-primary" %>
    <%= link_to "Cancel", return_policy.persisted? ? return_policy_path(return_policy) : return_policies_path, class: "button button-outline" %>
  </div>
<% end %>
