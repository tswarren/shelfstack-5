<%= form_with model: return_reason, class: "form" do |form| %>
  <%= render "shared/form_errors", object: return_reason %>

  <section class="form-section">
    <h2 class="form-section-title">Details</h2>
    <div class="form-grid">
      <div class="field">
        <%= form.label :code, class: "field-label" %>
        <% if return_reason.persisted? %>
          <%= form.text_field :code, class: "input input-code", disabled: true %>
        <% else %>
          <%= form.text_field :code, class: "input input-code" %>
        <% end %>
      </div>
      <div class="field">
        <%= form.label :name, class: "field-label" %>
        <%= form.text_field :name, class: "input" %>
      </div>
      <div class="field">
        <%= form.label :default_return_disposition, class: "field-label" %>
        <%= form.text_field :default_return_disposition, class: "input" %>
        <p class="field-hint">Default disposition applied to returned merchandise for this reason.</p>
      </div>
    </div>
    <div class="checkbox-group">
      <label><%= form.check_box :active %> Return reason is active</label>
    </div>
  </section>

  <div class="form-actions">
    <%= form.submit return_reason.persisted? ? "Update return reason" : "Create return reason", class: "button button-primary" %>
    <%= link_to "Cancel", return_reason.persisted? ? return_reason_path(return_reason) : return_reasons_path, class: "button button-outline" %>
  </div>
<% end %>
