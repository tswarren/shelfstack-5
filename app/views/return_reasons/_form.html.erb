<%= form_with model: return_reason do |form| %>
  <% if return_reason.errors.any? %>
    <ul>
      <% return_reason.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  <% end %>
  <% if return_reason.persisted? %>
    <div><%= form.label :code %> <%= return_reason.code %></div>
  <% else %>
    <div><%= form.label :code %> <%= form.text_field :code %></div>
  <% end %>
  <div><%= form.label :name %> <%= form.text_field :name %></div>
  <div><%= form.label :default_return_disposition %> <%= form.text_field :default_return_disposition %></div>
  <div><%= form.label :active %> <%= form.check_box :active %></div>
  <div><%= form.submit %></div>
<% end %>
