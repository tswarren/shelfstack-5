<%= render "shared/page_header",
      title: @inventory_adjustment_reason.name,
      breadcrumbs: [ { label: "Inventory adjustment reasons", path: inventory_adjustment_reasons_path }, { label: @inventory_adjustment_reason.name } ],
      actions: capture {
        if Current.user.can?("classification.reason.manage", store: Current.store)
          concat link_to("Edit", edit_inventory_adjustment_reason_path(@inventory_adjustment_reason), class: "button button-primary")
        end
        concat link_to("Back to reasons", inventory_adjustment_reasons_path, class: "button button-outline")
      } %>

<section class="record-section">
  <h2>Details</h2>
  <%= render "shared/record_summary", rows: [
    [ "Code", tag.code(@inventory_adjustment_reason.qualified_code) ],
    [ "Name", @inventory_adjustment_reason.name ],
    [ "Kind", @inventory_adjustment_reason.adjustment_kind.titleize ],
    [ "Requires note", @inventory_adjustment_reason.requires_note? ? "Yes" : "No" ],
    [ "Position", @inventory_adjustment_reason.position ],
    [ "Description", @inventory_adjustment_reason.description.presence || "—" ],
    [ "Status", boolean_status(@inventory_adjustment_reason.active?) ]
  ] %>
</section>
