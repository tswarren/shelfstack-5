<%= render "shared/page_header",
      title: @department.name,
      breadcrumbs: [ { label: "Departments", path: departments_path }, { label: @department.name } ],
      actions: capture {
        if Current.user.can?("classification.department.manage", store: Current.store)
          concat link_to("Edit", edit_department_path(@department), class: "button button-primary")
        end
        concat link_to("Back to departments", departments_path, class: "button button-outline")
      } %>

<section class="record-section">
  <h2>Identity</h2>
  <%= render "shared/record_summary", rows: [
    [ "Code", tag.code(@department.code) ],
    [ "Number", @department.department_number ],
    [ "Name", @department.name ],
    [ "Parent", @department.parent_department&.code || "—" ],
    [ "Postable", @department.postable? ? "Yes" : "No" ],
    [ "Status", boolean_status(@department.active?) ]
  ] %>
</section>

<section class="record-section">
  <h2>Policy &amp; pricing</h2>
  <%= render "shared/record_summary", rows: [
    [ "Default tax category", @department.default_tax_category&.code || "—" ],
    [ "Default return policy", @department.default_return_policy&.code || "—" ],
    [ "Maximum merchandise discount", @department.maximum_merchandise_discount ? format_rate_as_percent(@department.maximum_merchandise_discount) : "—" ],
    [ "Default cost estimation margin", @department.default_cost_estimation_margin_bps ? format_bps_as_percent(@department.default_cost_estimation_margin_bps) : "—" ]
  ] %>
</section>

<section class="record-section">
  <h2>GL account codes</h2>
  <%= render "shared/record_summary", rows: [
    [ "Inventory asset", @department.inventory_asset_gl_account_code.presence || "—" ],
    [ "Sales revenue", @department.sales_revenue_gl_account_code.presence || "—" ],
    [ "Sales returns", @department.sales_returns_gl_account_code.presence || "—" ],
    [ "Sales discounts", @department.sales_discounts_gl_account_code.presence || "—" ],
    [ "COGS", @department.cogs_gl_account_code.presence || "—" ],
    [ "Vendor returns", @department.vendor_returns_gl_account_code.presence || "—" ],
    [ "Inventory shrinkage", @department.inventory_shrinkage_gl_account_code.presence || "—" ],
    [ "Inventory write-down", @department.inventory_write_down_gl_account_code.presence || "—" ],
    [ "Inventory adjustment", @department.inventory_adjustment_gl_account_code.presence || "—" ],
    [ "Freight in", @department.freight_in_gl_account_code.presence || "—" ]
  ] %>
</section>
