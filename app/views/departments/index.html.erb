<h1>Departments</h1>
<p><%= link_to "New department", new_department_path if Current.user.can?("classification.department.manage", store: Current.store) %></p>
<ul>
  <% @departments.each do |department| %>
    <li><%= link_to "#{department.department_number} — #{department.name}", department %></li>
  <% end %>
</ul>
<p><%= link_to "Home", root_path %></p>
