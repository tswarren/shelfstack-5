<% content_for :title, "Reports" %>

<%= render "shared/page_header", title: "Reports",
      subtitle: "Read-only operational views and Phase 7 report pack over posted facts." %>

<div class="workspace-landing">
  <% if @can_reconcile %>
    <section class="card workspace-card">
      <h2>Reconciliations</h2>
      <p class="muted">Pending session and business-day reconciliation queue.</p>
      <div class="page-actions">
        <%= link_to "Open queue", reconciliations_path, class: "button button-outline" %>
      </div>
    </section>
  <% end %>

  <% if @can_view_sales %>
    <section class="card workspace-card">
      <h2>Commercial activity</h2>
      <p class="muted">Gross, discounts, returns, net sales by business-day reporting date.</p>
      <div class="page-actions">
        <%= link_to "View", commercial_activity_report_path, class: "button button-outline" %>
      </div>
    </section>
  <% end %>

  <% if @can_view_tenders %>
    <section class="card workspace-card">
      <h2>Tender activity</h2>
      <p class="muted">Received, refunded, and net by tender category.</p>
      <div class="page-actions">
        <%= link_to "View", tender_activity_report_path, class: "button button-outline" %>
      </div>
    </section>
  <% end %>

  <% if @can_view_tax %>
    <section class="card workspace-card">
      <h2>Tax activity</h2>
      <p class="muted">Completed tax components by receipt code.</p>
      <div class="page-actions">
        <%= link_to "View", tax_activity_report_path, class: "button button-outline" %>
      </div>
    </section>
  <% end %>

  <% if @can_view_inventory %>
    <section class="card workspace-card">
      <h2>Current stock</h2>
      <p class="muted">On-hand, reserved, unavailable, available, and on-order as-of now.</p>
      <div class="page-actions">
        <%= link_to "View", stock_snapshot_report_path, class: "button button-outline" %>
      </div>
    </section>
  <% end %>

  <% if @can_view_stored_value %>
    <section class="card workspace-card">
      <h2>Stored-value activity</h2>
      <p class="muted">Store-scoped issued, reloaded, redeemed, and refunded activity from completed POS.</p>
      <div class="page-actions">
        <%= link_to "View", stored_value_liability_report_path, class: "button button-outline" %>
      </div>
    </section>
  <% end %>

  <% if @can_view_audit %>
    <section class="card workspace-card">
      <h2>Integrity diagnostics</h2>
      <p class="muted">Non-blocking stock, snapshot, cost, and stored-value checks.</p>
      <div class="page-actions">
        <%= link_to "View", integrity_diagnostics_report_path, class: "button button-outline" %>
      </div>
    </section>
  <% end %>

  <% if @can_view_purchase_orders %>
    <section class="card workspace-card">
      <h2>Open purchase orders</h2>
      <p class="muted">Draft and ordered purchase orders with derived receiving state.</p>
      <div class="page-actions">
        <%= link_to "View", open_purchase_orders_report_path, class: "button button-outline" %>
      </div>
    </section>

    <section class="card workspace-card">
      <h2>On order</h2>
      <p class="muted">Derived on-order quantity by product variant, summed across ordered purchase orders.</p>
      <div class="page-actions">
        <%= link_to "View", on_order_report_path, class: "button button-outline" %>
      </div>
    </section>

    <section class="card workspace-card">
      <h2>Allocation events</h2>
      <p class="muted">Append-only history of Purchase-Order Allocation conversions and releases.</p>
      <div class="page-actions">
        <%= link_to "View", allocation_events_report_path, class: "button button-outline" %>
      </div>
    </section>
  <% end %>

  <% if @can_view_receipts %>
    <section class="card workspace-card">
      <h2>Receiving history</h2>
      <p class="muted">Receipt history and purchase orders that are only partially received.</p>
      <div class="page-actions">
        <%= link_to "View", receiving_history_report_path, class: "button button-outline" %>
      </div>
    </section>
  <% end %>

  <% if @can_view_requests %>
    <section class="card workspace-card">
      <h2>Buyer review</h2>
      <p class="muted">Open Product Requests awaiting a buyer decision.</p>
      <div class="page-actions">
        <%= link_to "View", buyer_review_index_path, class: "button button-outline" %>
      </div>
    </section>

    <section class="card workspace-card">
      <h2>Customer request coverage</h2>
      <p class="muted">Reserved, allocated, fulfilled, and uncovered quantity for Customer Requests.</p>
      <div class="page-actions">
        <%= link_to "View", customer_requests_report_path, class: "button button-outline" %>
      </div>
    </section>
  <% end %>
</div>
