<%# locals: name:, label:, value_percent: nil, id: nil, hint: nil, required: false, describedby: nil %>
<%
  field_id = local_assigns[:id].presence || "pf_#{name.to_s.gsub(/\W+/, "_")}"
  value = local_assigns[:value_percent].to_s.delete("%").strip
%>
<div class="field">
  <label class="field-label" for="<%= field_id %>"><%= label %></label>
  <div class="input-affix">
    <input id="<%= field_id %>" type="text" inputmode="decimal" autocomplete="off"
           class="input input-percent"
           name="<%= name %>"
           value="<%= value %>"
           placeholder="0"
           <%= "required" if local_assigns[:required] %>
           <%= "aria-describedby=\"#{local_assigns[:describedby]}\"".html_safe if local_assigns[:describedby].present? %>>
    <span class="affix" aria-hidden="true">%</span>
  </div>
  <% if local_assigns[:hint].present? %>
    <p class="field-hint" id="<%= field_id %>_hint"><%= hint %></p>
  <% end %>
</div>
