<%# locals: object: %>
<% if object.errors.any? %>
  <div class="ss-alert ss-alert-danger form-errors" role="alert" tabindex="-1" id="form-errors">
    <div>
      <p><strong><%= pluralize(object.errors.count, "error") %> prevented this record from being saved:</strong></p>
      <ul>
        <% object.errors.each do |error| %>
          <% attr = error.attribute %>
          <% field_id = attr == :base ? nil : "#{object.model_name.param_key}_#{attr}" %>
          <li>
            <% if field_id %>
              <a href="#<%= field_id %>"><%= error.full_message %></a>
            <% else %>
              <%= error.full_message %>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
<% end %>
