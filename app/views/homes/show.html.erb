<% content_for :title, "Home" %>

<%= render "shared/page_header", title: "Home", subtitle: "Workspace for #{Current.store.name}." %>

<div class="workspace-landing">
  <% if nav_permitted?("pos.access") %>
    <section class="card workspace-card">
      <h2>Register</h2>
      <p class="muted">Open the register, manage the business day and session, and run sales.</p>
      <div class="page-actions">
        <%= link_to "Go to register", register_path, class: "button button-primary" %>
      </div>
    </section>
  <% end %>

  <% if nav_permitted?("catalog.product.view") %>
    <section class="card workspace-card">
      <h2>Catalog</h2>
      <p class="muted">Find and maintain products and variants.</p>
      <div class="page-actions">
        <%= link_to "Products", products_path, class: "button button-outline" %>
      </div>
    </section>
  <% end %>

  <% if nav_permitted?("inventory.stock.view") %>
    <section class="card workspace-card">
      <h2>Inventory</h2>
      <p class="muted">Review stock balances and post adjustments.</p>
      <div class="page-actions">
        <%= link_to "Stock", stock_balances_path, class: "button button-outline" %>
        <%= link_to "Adjustments", inventory_adjustments_path, class: "button button-ghost" %>
      </div>
    </section>
  <% end %>
</div>

<p class="muted">Use the sidebar for configuration and administration.</p>
