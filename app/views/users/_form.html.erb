<%= form_with model: user do |form| %>
  <% if user.errors.any? %>
    <ul>
      <% user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  <% end %>
  <div><%= form.label :username %> <%= form.text_field :username %></div>
  <div><%= form.label :first_name %> <%= form.text_field :first_name %></div>
  <div><%= form.label :last_name %> <%= form.text_field :last_name %></div>
  <div><%= form.label :email %> <%= form.email_field :email %></div>
  <div><%= form.label :password %> <%= form.password_field :password %></div>
  <div><%= form.label :password_confirmation %> <%= form.password_field :password_confirmation %></div>
  <div><%= form.label :active %> <%= form.check_box :active %></div>
  <div><%= form.submit %></div>
<% end %>
