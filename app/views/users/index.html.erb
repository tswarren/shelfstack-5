<%= render "shared/page_header", title: "Users", subtitle: "People who can be granted store access.", actions: capture {
  if Current.user.can?("administration.user.manage", store: Current.store)
    concat link_to("New user", new_user_path, class: "button button-primary")
  end
} %>

<% if @users.empty? %>
  <%= render "shared/empty_state", title: "No users yet",
        body: "Create your first user to get started." %>
<% else %>
  <div class="table-container">
    <table class="data-table">
      <caption class="sr-only">Users</caption>
      <thead>
        <tr>
          <th scope="col">Username</th>
          <th scope="col">Name</th>
          <th scope="col">Email</th>
          <th scope="col">Status</th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr class="<%= "is-inactive" unless user.active? %>">
            <td><%= link_to user.username, user %></td>
            <td><%= [ user.first_name, user.last_name ].compact_blank.join(" ").presence || "—" %></td>
            <td><%= user.email.presence || "—" %></td>
            <td><%= boolean_status user.active? %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
