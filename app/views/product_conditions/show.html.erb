<h1><%= @product_condition.name %></h1>
<p>Code: <%= @product_condition.code %></p>
<p>Position: <%= @product_condition.position %></p>
<p>Active: <%= @product_condition.active %></p>
<p><%= link_to "Edit", edit_product_condition_path(@product_condition) if Current.user.can?("catalog.condition.manage", store: Current.store) %></p>
<p><%= link_to "All product conditions", product_conditions_path %></p>
