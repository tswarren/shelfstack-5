<h1>Inventory adjustments</h1>
<p><%= link_to "New adjustment", new_inventory_adjustment_path if Current.user.can?("inventory.adjustment.create", store: Current.store) %></p>
<ul>
  <% @inventory_adjustments.each do |adjustment| %>
    <li>
      <%= link_to "##{adjustment.id} #{adjustment.kind} (#{adjustment.status})", adjustment %>
    </li>
  <% end %>
</ul>
<p><%= link_to "Home", root_path %></p>
