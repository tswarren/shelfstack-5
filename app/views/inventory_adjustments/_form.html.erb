<% lines = inventory_adjustment.inventory_adjustment_lines.to_a
   lines = [ inventory_adjustment.inventory_adjustment_lines.build(quantity_delta: 1, position: 0) ] if lines.empty? %>

<%= form_with model: inventory_adjustment, class: "form",
      data: { controller: "inventory-adjustment-form" } do |form| %>
  <%= render "shared/form_errors", object: inventory_adjustment %>

  <section class="form-section">
    <h2 class="form-section-title">Document</h2>
    <div class="form-grid">
      <div class="field">
        <%= form.label :kind, class: "field-label" %>
        <%= form.select :kind, InventoryAdjustment::KINDS.map { |k| [ k.titleize, k ] },
              {},
              data: {
                inventory_adjustment_form_target: "kind",
                action: "change->inventory-adjustment-form#refresh"
              } %>
      </div>
      <div class="field">
        <%= form.label :inventory_adjustment_reason_id, "Reason", class: "field-label" %>
        <select name="inventory_adjustment[inventory_adjustment_reason_id]"
                id="inventory_adjustment_inventory_adjustment_reason_id"
                data-inventory-adjustment-form-target="reason">
          <% reasons.each do |reason| %>
            <option value="<%= reason.id %>"
                    data-inventory-adjustment-form-target="reasonOption"
                    data-adjustment-kind="<%= reason.adjustment_kind %>"
                    <%= "selected" if reason.id == inventory_adjustment.inventory_adjustment_reason_id %>>
              <%= reason.name %>
            </option>
          <% end %>
        </select>
      </div>
    </div>
    <div class="field">
      <%= form.label :note, class: "field-label" %>
      <%= form.text_area :note, class: "input", rows: 3 %>
      <p class="field-hint">May be blank while drafting; required at post when the reason requires a note.</p>
    </div>
  </section>

  <section class="form-section">
    <div class="page-header-row">
      <h2 class="form-section-title">Lines</h2>
      <button type="button" class="button button-outline button-small"
              data-action="inventory-adjustment-form#addLine">Add line</button>
    </div>

    <div data-inventory-adjustment-form-target="lines">
      <% lines.each_with_index do |line, index| %>
        <%= form.fields_for :inventory_adjustment_lines, line, child_index: index do |line_form| %>
          <%= render "line_fields", f: line_form, variants: variants %>
        <% end %>
      <% end %>
    </div>

    <template data-inventory-adjustment-form-target="lineTemplate">
      <%= form.fields_for :inventory_adjustment_lines, InventoryAdjustmentLine.new(quantity_delta: 1),
            child_index: "__INDEX__" do |line_form| %>
        <%= render "line_fields", f: line_form, variants: variants %>
      <% end %>
    </template>
  </section>

  <div class="form-actions">
    <%= form.submit(inventory_adjustment.persisted? ? "Update draft" : "Create draft", class: "button button-primary") %>
    <%= link_to "Cancel", inventory_adjustment.persisted? ? inventory_adjustment_path(inventory_adjustment) : inventory_adjustments_path, class: "button button-outline" %>
  </div>
<% end %>
