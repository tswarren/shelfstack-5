<%= form_with model: membership, class: "form" do |form| %>
  <%= render "shared/form_errors", object: membership %>

  <section class="form-section">
    <h2 class="form-section-title">Grant</h2>
    <div class="form-grid">
      <% if membership.persisted? %>
        <div class="field">
          <span class="field-label">User</span>
          <p><%= membership.user.username %></p>
        </div>
      <% else %>
        <div class="field">
          <%= form.label :user_id, "User", class: "field-label" %>
          <%= form.collection_select :user_id, users, :id, :username, include_blank: true %>
        </div>
      <% end %>
      <div class="field">
        <%= form.label :role_id, "Role", class: "field-label" %>
        <%= form.collection_select :role_id, roles, :id, :name, include_blank: true %>
      </div>
      <div class="field">
        <%= form.label :starts_on, class: "field-label" %>
        <%= form.date_field :starts_on, class: "input input-date" %>
      </div>
      <div class="field">
        <%= form.label :ends_on, class: "field-label" %>
        <%= form.date_field :ends_on, class: "input input-date" %>
      </div>
    </div>
    <div class="checkbox-group">
      <label><%= form.check_box :active %> Membership is active</label>
    </div>
  </section>

  <section class="form-section">
    <h2 class="form-section-title">Authority overrides (optional)</h2>
    <p class="field-hint">Leave blank to deny until configured. Rates are entered as percentages; amounts as dollars.</p>
    <div class="form-grid">
      <%= render "shared/percent_field", name: "store_membership[maximum_discount_rate_percent]",
            label: "Maximum discount rate", id: "store_membership_maximum_discount_rate",
            value_percent: format_rate_as_percent(membership.maximum_discount_rate),
            value: params.dig(:store_membership, :maximum_discount_rate_percent),
            object: membership, error_attr: :maximum_discount_rate,
            hint: "e.g. 20 for 20%." %>
      <%= render "shared/percent_field", name: "store_membership[maximum_price_override_rate_percent]",
            label: "Maximum price override rate", id: "store_membership_maximum_price_override_rate",
            value_percent: format_rate_as_percent(membership.maximum_price_override_rate),
            value: params.dig(:store_membership, :maximum_price_override_rate_percent),
            object: membership, error_attr: :maximum_price_override_rate,
            hint: "e.g. 15 for 15%." %>
      <%= render "shared/money_field", name: "store_membership[maximum_discount_amount]",
            label: "Maximum discount amount", id: "store_membership_maximum_discount_amount",
            value_cents: membership.maximum_discount_amount_cents,
            value: params.dig(:store_membership, :maximum_discount_amount),
            object: membership, error_attr: :maximum_discount_amount_cents %>
      <%= render "shared/money_field", name: "store_membership[maximum_cash_refund]",
            label: "Maximum cash refund", id: "store_membership_maximum_cash_refund",
            value_cents: membership.maximum_cash_refund_cents,
            value: params.dig(:store_membership, :maximum_cash_refund),
            object: membership, error_attr: :maximum_cash_refund_cents %>
      <%= render "shared/money_field", name: "store_membership[maximum_no_receipt_return]",
            label: "Maximum no-receipt return", id: "store_membership_maximum_no_receipt_return",
            value_cents: membership.maximum_no_receipt_return_cents,
            value: params.dig(:store_membership, :maximum_no_receipt_return),
            object: membership, error_attr: :maximum_no_receipt_return_cents %>
      <%= render "shared/money_field", name: "store_membership[maximum_paid_out]",
            label: "Maximum paid out", id: "store_membership_maximum_paid_out",
            value_cents: membership.maximum_paid_out_cents,
            value: params.dig(:store_membership, :maximum_paid_out),
            object: membership, error_attr: :maximum_paid_out_cents %>
      <%= render "shared/money_field", name: "store_membership[cash_variance_review_threshold]",
            label: "Cash variance review threshold", id: "store_membership_cash_variance_review_threshold",
            value_cents: membership.cash_variance_review_threshold_cents,
            value: params.dig(:store_membership, :cash_variance_review_threshold),
            object: membership, error_attr: :cash_variance_review_threshold_cents %>
    </div>
  </section>

  <div class="form-actions">
    <%= form.submit membership.persisted? ? "Update membership" : "Create membership", class: "button button-primary" %>
    <%= link_to "Cancel", store_memberships_path, class: "button button-outline" %>
  </div>
<% end %>
