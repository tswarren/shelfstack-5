<%= form_with model: merchandise_class, class: "form" do |form| %>
  <%= render "shared/form_errors", object: merchandise_class %>

  <section class="form-section">
    <h2 class="form-section-title">Details</h2>
    <div class="form-grid">
      <div class="field">
        <%= form.label :code, class: "field-label" %>
        <% if merchandise_class.persisted? %>
          <%= form.text_field :code, class: "input input-code", disabled: true %>
        <% else %>
          <%= form.text_field :code, class: "input input-code" %>
        <% end %>
      </div>
      <div class="field">
        <%= form.label :name, class: "field-label" %>
        <%= form.text_field :name, class: "input" %>
      </div>
      <div class="field">
        <%= form.label :level, class: "field-label" %>
        <%= form.select :level, MerchandiseClass::LEVELS.map { |l| [ l.titleize, l ] } %>
      </div>
      <div class="field">
        <%= form.label :parent_id, "Parent class", class: "field-label" %>
        <%= form.collection_select :parent_id, parent_classes.reject { |c| c.id == merchandise_class.id }, :id, :code, include_blank: true %>
      </div>
      <div class="field">
        <%= form.label :position, class: "field-label" %>
        <%= form.number_field :position, class: "input" %>
      </div>
    </div>
  </section>

  <section class="form-section">
    <h2 class="form-section-title">Default departments</h2>
    <div class="form-grid">
      <div class="field">
        <%= form.label :default_department_id, "Default department", class: "field-label" %>
        <%= form.collection_select :default_department_id, departments, :id, :code, include_blank: true %>
      </div>
      <div class="field">
        <%= form.label :default_used_department_id, "Default used department", class: "field-label" %>
        <%= form.collection_select :default_used_department_id, departments, :id, :code, include_blank: true %>
      </div>
    </div>
  </section>

  <section class="form-section">
    <h2 class="form-section-title">Status</h2>
    <div class="checkbox-group">
      <label><%= form.check_box :active %> Merchandise class is active</label>
    </div>
  </section>

  <div class="form-actions">
    <%= form.submit merchandise_class.persisted? ? "Update merchandise class" : "Create merchandise class", class: "button button-primary" %>
    <%= link_to "Cancel", merchandise_class.persisted? ? merchandise_class_path(merchandise_class) : merchandise_classes_path, class: "button button-outline" %>
  </div>
<% end %>
