<%= form_with model: store, class: "form" do |form| %>
  <%= render "shared/form_errors", object: store %>

  <section class="form-section">
    <h2 class="form-section-title">Store details</h2>
    <div class="form-grid">
      <div class="field">
        <%= form.label :code, class: "field-label" %>
        <%= form.text_field :code, class: "input input-code" %>
      </div>
      <div class="field">
        <%= form.label :name, class: "field-label" %>
        <%= form.text_field :name, class: "input" %>
      </div>
      <div class="field">
        <%= form.label :timezone, class: "field-label" %>
        <%= form.text_field :timezone, class: "input" %>
        <p class="field-hint">IANA time zone, e.g. America/New_York.</p>
      </div>
      <div class="field">
        <%= form.label :currency_code, class: "field-label" %>
        <%= form.text_field :currency_code, class: "input input-code", maxlength: 3 %>
        <p class="field-hint">ISO 4217 code, e.g. USD.</p>
      </div>
    </div>
    <div class="checkbox-group">
      <label><%= form.check_box :active %> Store is active</label>
    </div>
  </section>

  <div class="form-actions">
    <%= form.submit store.persisted? ? "Update store" : "Create store", class: "button button-primary" %>
    <%= link_to "Cancel", store.persisted? ? store_path(store) : stores_path, class: "button button-outline" %>
  </div>
<% end %>
