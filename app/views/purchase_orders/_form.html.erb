<% lines = purchase_order.purchase_order_lines.to_a
   lines = [ purchase_order.purchase_order_lines.build(ordered_quantity: 1, cost_entry_method: "discount_from_list", position: 0) ] if lines.empty? %>

<%= form_with model: purchase_order, class: "form", data: { controller: "purchase-order-form" } do |form| %>
  <%= render "shared/form_errors", object: purchase_order %>

  <section class="form-section">
    <h2 class="form-section-title">Document</h2>
    <div class="form-grid">
      <div class="field">
        <%= form.label :vendor_id, "Vendor", class: "field-label" %>
        <%= form.collection_select :vendor_id, @vendors, :id, :name, { include_blank: true }, required: true, class: "input" %>
      </div>
      <div class="field">
        <%= form.label :buyer_user_id, "Buyer", class: "field-label" %>
        <%= form.collection_select :buyer_user_id, @buyers, :id, :username, { include_blank: true }, class: "input" %>
      </div>
      <div class="field">
        <%= form.label :ordered_on, "Order date", class: "field-label" %>
        <%= form.date_field :ordered_on, class: "input" %>
      </div>
      <div class="field">
        <%= form.label :expected_on, "Expected date", class: "field-label" %>
        <%= form.date_field :expected_on, class: "input" %>
      </div>
      <div class="field">
        <%= form.label :vendor_reference, "Vendor reference", class: "field-label" %>
        <%= form.text_field :vendor_reference, class: "input" %>
      </div>
    </div>
    <div class="field">
      <%= form.label :notes, class: "field-label" %>
      <%= form.text_area :notes, class: "input", rows: 3 %>
    </div>
  </section>

  <section class="form-section">
    <div class="page-header-row">
      <h2 class="form-section-title">Lines</h2>
      <button type="button" class="button button-outline button-small"
              data-action="purchase-order-form#addLine">Add line</button>
    </div>

    <div data-purchase-order-form-target="lines">
      <% lines.each_with_index do |line, index| %>
        <%= form.fields_for :purchase_order_lines, line, child_index: index do |line_form| %>
          <%= render "line_fields", f: line_form, variants: @product_variants, product_variant_vendors: @product_variant_vendors %>
        <% end %>
      <% end %>
    </div>

    <template data-purchase-order-form-target="lineTemplate">
      <%= form.fields_for :purchase_order_lines, PurchaseOrderLine.new(ordered_quantity: 1, cost_entry_method: "discount_from_list"),
            child_index: "__INDEX__" do |line_form| %>
        <%= render "line_fields", f: line_form, variants: @product_variants, product_variant_vendors: @product_variant_vendors %>
      <% end %>
    </template>
  </section>

  <div class="form-actions">
    <%= form.submit(purchase_order.persisted? ? "Update draft" : "Create draft", class: "button button-primary") %>
    <%= link_to "Cancel", purchase_order.persisted? ? purchase_order_path(purchase_order) : purchase_orders_path, class: "button button-outline" %>
  </div>
<% end %>
