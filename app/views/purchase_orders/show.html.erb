<% content_for :title, @purchase_order.purchase_order_number %>

<%= render "shared/page_header",
      title: @purchase_order.purchase_order_number,
      subtitle: @purchase_order.vendor.name,
      breadcrumbs: [ { label: "Purchase orders", path: purchase_orders_path }, { label: @purchase_order.purchase_order_number } ],
      actions: capture {
        if @can_place
          concat button_to("Place order", place_purchase_order_path(@purchase_order), method: :post,
                class: "button button-primary",
                form: { data: { turbo_confirm: "Place this purchase order with the vendor?" } })
        end
        if @purchase_order.draft? && Current.user.can?("purchasing.purchase_order.edit", store: Current.store)
          concat link_to("Edit draft", edit_purchase_order_path(@purchase_order), class: "button button-outline")
        end
        if @can_close
          concat button_to("Close order", close_purchase_order_path(@purchase_order), method: :post,
                class: "button button-outline",
                form: { data: { turbo_confirm: "Close this purchase order? Phase 5 has no reopen workflow." } })
        end
        concat link_to("Back to purchase orders", purchase_orders_path, class: "button button-outline")
      } %>

<section class="record-section">
  <h2>Document</h2>
  <%= render "shared/record_summary", rows: [
    [ "Status", status_badge(@purchase_order.status.titleize, variant: purchase_order_status_variant(@purchase_order.status)) ],
    [ "Receiving", status_badge(@purchase_order.receiving_state.titleize, variant: purchase_order_receiving_state_variant(@purchase_order.receiving_state)) ],
    [ "Vendor", @purchase_order.vendor.name ],
    [ "Currency", @purchase_order.currency_code ],
    [ "Buyer", @purchase_order.buyer_user&.username || "—" ],
    [ "Ordered on", @purchase_order.ordered_on&.to_fs(:long) || "—" ],
    [ "Expected on", @purchase_order.expected_on&.to_fs(:long) || "—" ],
    [ "Vendor reference", @purchase_order.vendor_reference.presence || "—" ],
    [ "Notes", @purchase_order.notes.presence || "—" ]
  ] %>
  <% if @purchase_order.ordered? %>
    <%= render "shared/record_summary", rows: [
      [ "Placed at", formatted_datetime(@purchase_order.ordered_at) ],
      [ "Placed by", @purchase_order.ordered_by_user&.username || "—" ]
    ] %>
  <% end %>
  <% if @purchase_order.cancelled? %>
    <%= render "shared/record_summary", rows: [
      [ "Cancelled at", formatted_datetime(@purchase_order.cancelled_at) ],
      [ "Cancelled by", @purchase_order.cancelled_by_user&.username || "—" ]
    ] %>
  <% end %>
  <% if @purchase_order.closed? %>
    <%= render "shared/record_summary", rows: [
      [ "Closed at", formatted_datetime(@purchase_order.closed_at) ],
      [ "Closed by", @purchase_order.closed_by_user&.username || "—" ]
    ] %>
  <% end %>
</section>

<section class="record-section">
  <h2>Lines</h2>
  <div class="table-container">
    <table class="data-table">
      <caption class="sr-only">Purchase order lines</caption>
      <thead>
        <tr>
          <th scope="col">Variant</th>
          <th scope="col" class="num">Ordered</th>
          <th scope="col" class="num">Cancelled</th>
          <th scope="col" class="num">Received</th>
          <th scope="col" class="num">Open</th>
          <% if @can_view_cost %>
            <th scope="col" class="num">Unit cost</th>
            <th scope="col" class="num">Extended</th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% @purchase_order.purchase_order_lines.order(:position).each do |line| %>
          <tr>
            <td>
              <%= line.description_snapshot.presence || variant_option_label(line.product_variant) %>
              <div class="muted">SKU <%= line.sku_snapshot.presence || line.product_variant.sku %></div>
            </td>
            <td class="num"><%= line.ordered_quantity %></td>
            <td class="num"><%= line.cancelled_quantity %></td>
            <td class="num"><%= line.received_quantity %></td>
            <td class="num"><%= line.open_quantity %></td>
            <% if @can_view_cost %>
              <td class="num"><%= format_money(line.expected_unit_cost_cents, currency_code: @purchase_order.currency_code) %></td>
              <td class="num"><%= format_money(line.expected_extended_cost_cents, currency_code: @purchase_order.currency_code) %></td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<% if @can_amend %>
  <section class="record-section">
    <h2>Amend</h2>
    <p class="field-hint">
      Cancel remaining open quantity on a line, or add a new line to increase supply.
      Ordered quantity and cost on existing lines cannot be edited in place.
    </p>

    <%= form_with url: amend_purchase_order_path(@purchase_order), method: :post, class: "form" do |form| %>
      <div class="field">
        <%= form.label "purchase_order[amend_reason]", "Reason" %>
        <%= form.text_field "purchase_order[amend_reason]", id: "purchase_order_amend_reason", class: "input" %>
        <p class="field-hint">Required when cancelling quantity on a line.</p>
      </div>

      <div class="table-container">
        <table class="data-table">
          <caption class="sr-only">Cancel remaining quantity</caption>
          <thead>
            <tr>
              <th scope="col">Variant</th>
              <th scope="col" class="num">Open</th>
              <th scope="col" class="num">New cancelled quantity</th>
            </tr>
          </thead>
          <tbody>
            <% @purchase_order.purchase_order_lines.order(:position).select { |l| l.open_quantity.positive? }.each do |line| %>
              <tr>
                <td><%= line.description_snapshot.presence || variant_option_label(line.product_variant) %></td>
                <td class="num"><%= line.open_quantity %></td>
                <td class="num">
                  <%= hidden_field_tag "purchase_order[cancel_lines_attributes][][id]", line.id %>
                  <%= number_field_tag "purchase_order[cancel_lines_attributes][][cancelled_quantity]",
                        line.cancelled_quantity, min: line.cancelled_quantity, max: line.ordered_quantity, class: "input" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <h3 class="form-section-title">Add new line</h3>
      <div class="form-grid">
        <div class="field">
          <%= label_tag "purchase_order_new_line_variant", "Product variant" %>
          <%= select_tag "purchase_order[new_lines_attributes][][product_variant_id]",
                options_for_select(@vendor_variant_options),
                { include_blank: true }, id: "purchase_order_new_line_variant", class: "input" %>
        </div>
        <div class="field">
          <%= label_tag "purchase_order_new_line_quantity", "Ordered quantity" %>
          <%= number_field_tag "purchase_order[new_lines_attributes][][ordered_quantity]", nil, min: 1, id: "purchase_order_new_line_quantity", class: "input" %>
        </div>
        <div class="field">
          <%= label_tag "purchase_order_new_line_method", "Cost entry method" %>
          <%= select_tag "purchase_order[new_lines_attributes][][cost_entry_method]",
                options_for_select(PurchaseOrderLine::COST_ENTRY_METHODS.map { |m| [ m.titleize, m ] }),
                id: "purchase_order_new_line_method", class: "input" %>
        </div>
        <div class="field">
          <%= label_tag "purchase_order_new_line_list_cost", "List cost (cents)" %>
          <%= number_field_tag "purchase_order[new_lines_attributes][][list_cost_cents]", nil, min: 0, id: "purchase_order_new_line_list_cost", class: "input" %>
        </div>
        <div class="field">
          <%= label_tag "purchase_order_new_line_discount", "Discount (bps)" %>
          <%= number_field_tag "purchase_order[new_lines_attributes][][discount_bps]", nil, min: 0, max: 10_000, id: "purchase_order_new_line_discount", class: "input" %>
        </div>
        <div class="field">
          <%= label_tag "purchase_order_new_line_unit_cost", "Expected unit cost (cents)" %>
          <%= number_field_tag "purchase_order[new_lines_attributes][][expected_unit_cost_cents]", nil, min: 0, id: "purchase_order_new_line_unit_cost", class: "input" %>
        </div>
      </div>

      <div class="form-actions">
        <%= form.submit "Amend purchase order", class: "button button-primary" %>
      </div>
    <% end %>
  </section>
<% end %>

<% if @can_cancel %>
  <section class="record-section">
    <h2>Cancel</h2>
    <p class="field-hint">Cancellation is only permitted while no quantity has been received.</p>
    <%= form_with url: cancel_purchase_order_path(@purchase_order), method: :post, class: "form",
          data: { turbo_confirm: "Cancel this purchase order?" } do |form| %>
      <div class="field">
        <%= form.label "purchase_order[cancel_reason]", "Cancel reason" %>
        <%= form.text_field "purchase_order[cancel_reason]", id: "purchase_order_cancel_reason", class: "input" %>
      </div>
      <div class="form-actions">
        <%= form.submit "Cancel purchase order", class: "button button-danger" %>
      </div>
    <% end %>
  </section>
<% end %>
