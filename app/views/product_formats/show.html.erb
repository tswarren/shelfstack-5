<%= render "shared/page_header",
      title: @product_format.name,
      breadcrumbs: [ { label: "Product formats", path: product_formats_path }, { label: @product_format.name } ],
      actions: capture {
        if Current.user.can?("catalog.format.manage", store: Current.store)
          concat link_to("Edit", edit_product_format_path(@product_format), class: "button button-primary")
        end
        concat link_to("Back to product formats", product_formats_path, class: "button button-outline")
      } %>

<section class="record-section">
  <h2>Details</h2>
  <%= render "shared/record_summary", rows: [
    [ "Code", tag.code(@product_format.code) ],
    [ "Name", @product_format.name ],
    [ "Short code", @product_format.short_code.presence || "—" ],
    [ "Format family", @product_format.format_family.presence || "—" ],
    [ "Default tracking mode", @product_format.default_inventory_tracking_mode.titleize ],
    [ "Status", boolean_status(@product_format.active?) ]
  ] %>
</section>
