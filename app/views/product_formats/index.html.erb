<%= render "shared/page_header", title: "Product formats",
      subtitle: "Format definitions and their default inventory tracking mode.",
      actions: capture {
        if Current.user.can?("catalog.format.manage", store: Current.store)
          concat link_to("New product format", new_product_format_path, class: "button button-primary")
        end
      } %>

<% if @product_formats.empty? %>
  <%= render "shared/empty_state", title: "No product formats yet",
        body: "Create your first product format to get started." %>
<% else %>
  <div class="table-container">
    <table class="data-table">
      <caption class="sr-only">Product formats</caption>
      <thead>
        <tr>
          <th scope="col">Code</th>
          <th scope="col">Name</th>
          <th scope="col">Family</th>
          <th scope="col">Tracking mode</th>
          <th scope="col">Status</th>
        </tr>
      </thead>
      <tbody>
        <% @product_formats.each do |product_format| %>
          <tr class="<%= "is-inactive" unless product_format.active? %>">
            <td><code><%= product_format.code %></code></td>
            <td><%= link_to product_format.name, product_format %></td>
            <td><%= product_format.format_family.presence || "—" %></td>
            <td><%= product_format.default_inventory_tracking_mode.titleize %></td>
            <td><%= boolean_status product_format.active? %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
