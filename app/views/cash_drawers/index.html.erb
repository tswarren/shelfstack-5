<%= render "shared/page_header", title: "Cash drawers",
      subtitle: "Cash drawers registered to #{Current.store.name}.",
      actions: capture {
        concat link_to("New drawer", new_cash_drawer_path, class: "button button-primary")
      } %>

<% if @drawers.empty? %>
  <%= render "shared/empty_state", title: "No drawers yet",
        body: "Register your first cash drawer to get started.",
        actions: capture { concat link_to("New drawer", new_cash_drawer_path, class: "button button-primary") } %>
<% else %>
  <div class="table-container">
    <table class="data-table">
      <caption class="sr-only">Cash drawers</caption>
      <thead>
        <tr>
          <th scope="col">Code</th>
          <th scope="col">Name</th>
          <th scope="col">Status</th>
          <th scope="col" class="row-actions"></th>
        </tr>
      </thead>
      <tbody>
        <% @drawers.each do |drawer| %>
          <tr class="<%= "is-inactive" unless drawer.active? %>">
            <td><code><%= drawer.code %></code></td>
            <td><%= drawer.name %></td>
            <td><%= boolean_status drawer.active? %></td>
            <td class="row-actions"><%= link_to "Edit", edit_cash_drawer_path(drawer), class: "button button-outline" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
