<% content_for :title, "Reconcile session ##{@session.id}" %>

<%= render "shared/page_header", title: "Reconcile session ##{@session.id}",
      subtitle: @reconciliation.finalized? ? "Finalized" : "Draft" %>

<%= render "reconciliations/comparisons", reconciliation: @reconciliation %>

<% unless @reconciliation.finalized? %>
  <%= form_with url: finalize_reconciliation_path(@reconciliation), method: :post, local: true do %>
    <div class="form-row">
      <label for="reason">Reason (required when variance is nonzero)</label>
      <textarea id="reason" name="reason" rows="2"></textarea>
    </div>
    <div class="form-row">
      <label for="approver_username">Approver username (when over threshold)</label>
      <input id="approver_username" name="approver_username" type="text">
    </div>
    <div class="form-row">
      <label for="approver_pin">Approver PIN</label>
      <input id="approver_pin" name="approver_pin" type="password">
    </div>
    <div class="page-actions">
      <%= submit_tag "Reconcile now", class: "button" %>
      <%= link_to "Review later", reconciliations_path, class: "button button-outline" %>
    </div>
  <% end %>
<% end %>
