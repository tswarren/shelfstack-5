<% content_for :title, @product.name %>

<h1><%= @product.name %></h1>

<p><strong>Identifier:</strong> <%= @product.identifier %></p>
<% if @product.alternate_identifier.present? %>
  <p><strong>Alternate identifier:</strong> <%= @product.alternate_identifier %></p>
<% end %>
<p><strong>Status:</strong> <%= @product.status %></p>
<p><strong>Sellable:</strong> <%= @product.sellable? %></p>
<% if @product.identifier_warning.present? %>
  <p><strong>Identifier warning:</strong> <%= @product.identifier_warning %></p>
<% end %>

<h2>Variants</h2>
<ul>
  <% @variants.each do |variant| %>
    <li>
      <%= variant.name %> — SKU <%= variant.sku %>
      (<%= variant.inventory_tracking_mode %>, <%= variant.status %>)
    </li>
  <% end %>
</ul>

<p><%= link_to "Back", products_path %></p>
<% if Current.user.can?("catalog.product.edit", store: Current.store) %>
  <p><%= link_to "Edit", edit_product_path(@product) %></p>
<% end %>
