<%= form_with url: product.persisted? ? product_path(product) : products_path,
      method: product.persisted? ? :patch : :post, class: "form" do |form| %>
  <%= render "shared/form_errors", object: product, id: "form-errors-product" %>
  <% if variant.present? && variant.errors.any? %>
    <%= render "shared/form_errors", object: variant, id: "form-errors-variant" %>
  <% end %>

  <section class="form-section">
    <h2 class="form-section-title">Identity</h2>
    <% unless product.persisted? %>
      <div class="form-grid">
        <div class="field">
          <label class="field-label" for="identifier">Identifier</label>
          <input type="text" name="identifier" id="identifier" class="input"
                 value="<%= params[:identifier] %>">
          <p class="field-hint">Leave blank to generate a namespace 29 identifier.</p>
        </div>
      </div>
      <div class="checkbox-group">
        <label>
          <input type="checkbox" name="accept_identifier_warning" id="accept_identifier_warning" value="1"
            <%= "checked" if params[:accept_identifier_warning] == "1" %>>
          Accept identifier warning (save despite an invalid check digit)
        </label>
      </div>
    <% else %>
      <%= render "shared/record_summary", rows: [ [ "Identifier", tag.code(product.identifier) ] ] %>
    <% end %>

    <%= fields_for :product, product do |product_form| %>
      <div class="form-grid">
        <div class="field">
          <%= product_form.label :name, class: "field-label" %>
          <%= product_form.text_field :name, class: "input", required: true %>
        </div>
        <div class="field">
          <%= product_form.label :subtitle, class: "field-label" %>
          <%= product_form.text_field :subtitle, class: "input" %>
        </div>
        <div class="field">
          <%= product_form.label :alternate_identifier, class: "field-label" %>
          <%= product_form.text_field :alternate_identifier, class: "input" %>
        </div>
        <div class="field">
          <%= product_form.label :product_type, class: "field-label" %>
          <%= product_form.select :product_type, Product::PRODUCT_TYPES.map { |t| [ t.titleize, t ] } %>
        </div>
        <div class="field">
          <%= product_form.label :publisher_or_manufacturer_name, "Publisher / manufacturer", class: "field-label" %>
          <%= product_form.text_field :publisher_or_manufacturer_name, class: "input" %>
        </div>
        <div class="field">
          <%= product_form.label :imprint_or_brand_name, "Imprint / brand", class: "field-label" %>
          <%= product_form.text_field :imprint_or_brand_name, class: "input" %>
        </div>
      </div>
    <% end %>
  </section>

  <%= fields_for :product, product do |product_form| %>
    <section class="form-section">
      <h2 class="form-section-title">Description</h2>
      <div class="field">
        <%= product_form.label :description, class: "field-label" %>
        <%= product_form.text_area :description, class: "input", rows: 4 %>
      </div>
    </section>

    <section class="form-section">
      <h2 class="form-section-title">Classification</h2>
      <div class="form-grid">
        <%= render "shared/record_picker",
              form: product_form,
              method: :product_format_id,
              record_type: "product_format",
              selected: product.product_format,
              label: "Format" %>
        <%= render "shared/record_picker",
              form: product_form,
              method: :merchandise_class_id,
              record_type: "merchandise_class",
              selected: product.merchandise_class,
              label: "Merchandise class" %>
        <%= render "shared/record_picker",
              form: product_form,
              method: :default_department_id,
              record_type: "department",
              selected: product.default_department,
              label: "Default department",
              hint: "Leave blank to inherit from the merchandise class when present." %>
        <%= render "shared/record_picker",
              form: product_form,
              method: :default_tax_category_id,
              record_type: "tax_category",
              selected: product.default_tax_category,
              label: "Default tax category",
              hint: "Leave blank to inherit from merchandise class or department." %>
      </div>
    </section>

    <section class="form-section">
      <h2 class="form-section-title">Pricing &amp; availability</h2>
      <div class="form-grid">
        <%= render "shared/money_field", name: "product[list_price]", label: "List price",
              value_cents: product.list_price_cents, id: "product_list_price",
              object: product, error_attr: :list_price,
              value: params.dig(:product, :list_price),
              hint: "Manufacturer list price. Enter dollars, e.g. 24.95." %>
        <div class="field">
          <%= product_form.label :available_from, class: "field-label" %>
          <%= product_form.date_field :available_from, class: "input input-date" %>
        </div>
        <div class="field">
          <%= product_form.label :available_until, class: "field-label" %>
          <%= product_form.date_field :available_until, class: "input input-date" %>
        </div>
      </div>
    </section>
  <% end %>

  <section class="form-section">
    <h2 class="form-section-title">Standard variant</h2>
    <%= fields_for :product_variant, variant do |variant_form| %>
      <div class="form-grid">
        <div class="field">
          <%= variant_form.label :inventory_tracking_mode, "Tracking mode", class: "field-label" %>
          <%= variant_form.select :inventory_tracking_mode, ProductVariant::INVENTORY_TRACKING_MODES.map { |m| [ m.titleize, m ] } %>
        </div>
        <%= render "shared/money_field", name: "product_variant[regular_price]", label: "Regular price",
              value_cents: variant.regular_price_cents, id: "product_variant_regular_price",
              object: variant, error_attr: :regular_price,
              value: params.dig(:product_variant, :regular_price),
              hint: "Required when the variant is sellable. Enter dollars, e.g. 12.95." %>
        <div class="field">
          <%= variant_form.label :status, class: "field-label" %>
          <%= variant_form.select :status, ProductVariant::STATUSES.map { |s| [ s.titleize, s ] } %>
        </div>
      </div>
      <div class="checkbox-group">
        <label><%= variant_form.check_box :sellable %> Variant is sellable</label>
      </div>
    <% end %>
  </section>

  <section class="form-section">
    <h2 class="form-section-title">Status</h2>
    <%= fields_for :product, product do |product_form| %>
      <div class="form-grid">
        <div class="field">
          <%= product_form.label :status, class: "field-label" %>
          <%= product_form.select :status, Product::STATUSES.map { |s| [ s.titleize, s ] } %>
        </div>
      </div>
      <div class="checkbox-group">
        <label><%= product_form.check_box :sellable %> Product is sellable</label>
      </div>
    <% end %>
  </section>

  <div class="form-actions">
    <%= form.submit product.persisted? ? "Update product" : "Create product", class: "button button-primary" %>
    <%= link_to "Cancel", product.persisted? ? product_path(product) : products_path, class: "button button-outline" %>
  </div>
<% end %>
