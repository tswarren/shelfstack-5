<% content_for :title, "Open session" %>

<%= render "shared/page_header", title: "Open session" %>

<%= form_with url: pos_sessions_path, scope: :pos_session, class: "form" do |form| %>
  <%= form.hidden_field :business_day_id, value: @business_day.id %>
  <div class="field">
    <%= form.label :pos_device_id, "Device", class: "field-label" %>
    <%= form.collection_select :pos_device_id, @devices, :id, :name, {}, class: "input" %>
  </div>
  <div class="field">
    <%= form.label :cash_drawer_id, "Drawer (optional)", class: "field-label" %>
    <%= form.collection_select :cash_drawer_id, @drawers, :id, :name, { include_blank: "Card-only (no drawer)" }, class: "input" %>
  </div>
  <%= render "shared/currency_field", name: "pos_session[opening_cash_cents]", label: "Opening cash",
        id: "opening_cash_cents", hint: "Required when a cash drawer is selected." %>
  <div class="form-actions">
    <%= form.submit "Open session", class: "button button-primary" %>
    <%= link_to "Cancel", register_path, class: "button button-ghost" %>
  </div>
<% end %>
