<% content_for :title, "Close session" %>

<%= render "shared/page_header", title: "Close cash session" %>

<%= render "shared/record_summary", rows: [
      [ "Opening cash", pos_money(@session.opening_cash_cents) ],
      [ "Expected cash", pos_money(@expected_cash_cents) ],
      ([ "Last recorded count", "#{pos_money(@closing_count.total_cents)} (#{@closing_count.count_type.humanize})" ] if @closing_count)
    ].compact %>

<% if @session.pos_cash_movements.any? %>
  <section class="pos-panel">
    <h2>Cash movements this session</h2>
    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th scope="col">Type</th>
            <th scope="col">Direction</th>
            <th scope="col" class="num">Amount</th>
            <th scope="col">Reference</th>
          </tr>
        </thead>
        <tbody>
          <% @session.pos_cash_movements.includes(:cash_movement_type).order(:id).each do |movement| %>
            <tr>
              <td><%= movement.cash_movement_type.name %></td>
              <td><%= movement.cash_movement_type.direction.humanize %></td>
              <td class="num"><%= pos_money(movement.amount_cents) %></td>
              <td><%= movement.reference.presence || "—" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
<% end %>

<%= form_with url: close_pos_session_path(@session), method: :post, class: "form" do |form| %>
  <%= render "shared/currency_field", name: "counted_cash_cents", label: "Counted cash",
        id: "counted_cash_cents", required: true,
        value_cents: (@closing_count&.total_cents || @expected_cash_cents),
        hint: (@closing_count ? "Submitting a different amount records a manager recount, then closes." : nil) %>
  <div class="form-actions">
    <%= form.submit(@closing_count ? "Close session" : "Record count and close", class: "button button-primary") %>
    <%= link_to "Cancel", register_path, class: "button button-ghost" %>
  </div>
<% end %>
