<%= form_with model: device do |form| %>
  <% if device.errors.any? %>
    <ul><% device.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
  <% end %>
  <div><%= form.label :code %> <%= form.text_field :code %></div>
  <div><%= form.label :name %> <%= form.text_field :name %></div>
  <div><%= form.label :device_type %> <%= form.select :device_type, PosDevice::DEVICE_TYPES %></div>
  <div><%= form.label :active %> <%= form.check_box :active %></div>
  <div><%= form.submit %></div>
<% end %>
