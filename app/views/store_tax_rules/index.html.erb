<%= render "shared/page_header", title: "Store tax rules",
      subtitle: "How tax categories are taxed at #{Current.store.name}.",
      actions: capture {
        if Current.user.can?("classification.store_tax_rule.manage", store: Current.store)
          concat link_to("New store tax rule", new_store_tax_rule_path, class: "button button-primary")
        end
        concat link_to("Store tax rates", store_tax_rates_path, class: "button button-outline")
      } %>

<% if @store_tax_rules.empty? %>
  <%= render "shared/empty_state", title: "No store tax rules yet",
        body: "Create your first store tax rule to get started." %>
<% else %>
  <div class="table-container">
    <table class="data-table">
      <caption class="sr-only">Store tax rules</caption>
      <thead>
        <tr>
          <th scope="col">Tax category</th>
          <th scope="col">Component</th>
          <th scope="col">Treatment</th>
          <th scope="col" class="num">Rate</th>
          <th scope="col" class="num">Taxable portion</th>
          <th scope="col" class="num">Order</th>
          <th scope="col">Compounds</th>
          <th scope="col">Status</th>
          <th scope="col" class="row-actions"></th>
        </tr>
      </thead>
      <tbody>
        <% @store_tax_rules.each do |rule| %>
          <tr class="<%= "is-inactive" unless rule.active? %>">
            <td>
              <%= rule.tax_category.name %>
              <br><span class="muted"><code><%= rule.tax_category.code %></code></span>
            </td>
            <td><%= rule.component_code %></td>
            <td><%= tax_treatment_label(rule.treatment) %></td>
            <td class="num"><%= rule.store_tax_rate ? format_rate_as_percent(rule.store_tax_rate.rate) : "—" %></td>
            <td class="num"><%= format_rate_as_percent(rule.taxable_fraction) %></td>
            <td class="num"><%= rule.calculation_order %></td>
            <td><%= rule.compounds_on_prior_tax? ? "Yes" : "No" %></td>
            <td><%= boolean_status rule.active? %></td>
            <td class="row-actions">
              <% if Current.user.can?("classification.store_tax_rule.manage", store: Current.store) %>
                <%= link_to "Edit", edit_store_tax_rule_path(rule), class: "button button-outline" %>
              <% end %>
            </td>
          </tr>
          <tr class="pos-line-detail-row">
            <td colspan="9" class="muted"><%= store_tax_rule_summary(rule) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
