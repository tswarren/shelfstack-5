<%= form_with model: store_tax_rule, class: "form" do |form| %>
  <%= render "shared/form_errors", object: store_tax_rule %>

  <section class="form-section">
    <h2 class="form-section-title">How store tax rules work</h2>
    <p class="muted">
      A rule connects a <strong>tax category</strong> (what is being sold) to a
      <strong>tax rate component</strong> (how it is taxed). Treatments:
      <em>Taxable</em> and <em>Zero-rated</em> need a rate;
      <em>Exempt</em> and <em>Not applicable</em> usually omit one.
      <em>Taxable portion</em> is the fraction of price subject to that component.
      <em>Compounds on prior tax</em> means this component taxes earlier tax amounts.
      Effective dates control when the rule applies.
    </p>
  </section>

  <section class="form-section">
    <h2 class="form-section-title">Applicability</h2>
    <div class="form-grid">
      <div class="field">
        <%= form.label :tax_category_id, "Tax category", class: "field-label" %>
        <%= form.select :tax_category_id, @tax_categories.map { |c| [ c.name, c.id ] }, {}, class: "input" %>
      </div>
      <div class="field">
        <%= form.label :store_tax_rate_id, "Store tax rate", class: "field-label" %>
        <%= form.select :store_tax_rate_id, @store_tax_rates.map { |r| [ record_option_label(r), r.id ] },
              { include_blank: true }, class: "input" %>
        <p class="field-hint">Leave blank for exempt or not-applicable treatments.</p>
      </div>
      <div class="field">
        <%= form.label :component_code, class: "field-label" %>
        <%= form.text_field :component_code, class: "input" %>
      </div>
      <div class="field">
        <%= form.label :treatment, class: "field-label" %>
        <%= form.select :treatment,
              StoreTaxRule::TREATMENTS.map { |t| [ tax_treatment_label(t), t ] },
              {}, class: "input" %>
      </div>
    </div>
  </section>

  <section class="form-section">
    <h2 class="form-section-title">Calculation</h2>
    <div class="form-grid">
      <%= render "shared/percent_field", name: "store_tax_rule[taxable_fraction_percent]",
            label: "Taxable portion", id: "store_tax_rule_taxable_fraction",
            value_percent: format_rate_as_percent(store_tax_rule.taxable_fraction),
            value: params.dig(:store_tax_rule, :taxable_fraction_percent),
            object: store_tax_rule, error_attr: :taxable_fraction,
            hint: "Portion of the price that is taxable, e.g. 100 for fully taxable." %>
      <div class="field">
        <%= form.label :calculation_order, class: "field-label" %>
        <%= form.number_field :calculation_order, class: "input", min: 0 %>
      </div>
    </div>
    <div class="checkbox-group">
      <label><%= form.check_box :compounds_on_prior_tax %> Compounds on prior tax</label>
    </div>
  </section>

  <section class="form-section">
    <h2 class="form-section-title">Effective period</h2>
    <div class="form-grid">
      <div class="field">
        <%= form.label :effective_from, class: "field-label" %>
        <%= form.date_field :effective_from, class: "input input-date" %>
      </div>
      <div class="field">
        <%= form.label :effective_to, class: "field-label" %>
        <%= form.date_field :effective_to, class: "input input-date" %>
      </div>
    </div>
    <div class="checkbox-group">
      <label><%= form.check_box :active %> Tax rule is active</label>
    </div>
  </section>

  <% if store_tax_rule.persisted? && store_tax_rule.tax_category.present? %>
    <section class="form-section">
      <h2 class="form-section-title">Summary</h2>
      <p><%= store_tax_rule_summary(store_tax_rule) %></p>
    </section>
  <% end %>

  <div class="form-actions">
    <%= form.submit store_tax_rule.persisted? ? "Update store tax rule" : "Create store tax rule", class: "button button-primary" %>
    <%= link_to "Cancel", store_tax_rules_path, class: "button button-outline" %>
  </div>
<% end %>
