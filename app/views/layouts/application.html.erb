<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? "#{content_for(:title)} · ShelfStack" : "ShelfStack" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="ShelfStack">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= shelfstack_stylesheet_tags %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="layout-application" data-controller="sidebar">
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <%= render "shared/app_header", mode: :back_office %>
    <div class="app-shell">
      <%= render "shared/sidebar" %>
      <div class="app-shell-main">
        <div class="app-main" id="main-content" tabindex="-1">
          <%= render "shared/flash_messages" %>
          <%= yield %>
        </div>
      </div>
    </div>
  </body>
</html>
