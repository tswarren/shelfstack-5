<% content_for :title, "Open business day" %>

<%= render "shared/page_header", title: "Open business day" %>

<%= form_with url: business_days_path, model: @business_day, scope: :business_day, class: "form" do |form| %>
  <div class="field">
    <%= form.label :reporting_date, class: "field-label" %>
    <%= form.date_field :reporting_date, class: "input input-date" %>
    <p class="field-hint">Defaults to today in the store's time zone if left as-is.</p>
  </div>
  <div class="form-actions">
    <%= form.submit "Open business day", class: "button button-primary" %>
    <%= link_to "Cancel", register_path, class: "button button-ghost" %>
  </div>
<% end %>
