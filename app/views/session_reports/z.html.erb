<% content_for :title, "Session Z ##{@z_report.z_number}" %>

<%= render "shared/page_header", title: "Session Z ##{@z_report.z_number}",
      subtitle: "Closed snapshot · definition #{@z_report.report_definition_version}." %>

<%= render "session_reports/payload_totals",
      payload: @payload,
      show_cash: @show_cash,
      show_cost: @show_cost,
      show_margin: @show_margin %>

<section class="card workspace-card" data-recon-cta="true">
  <h2>Reconciliation</h2>
  <% if @session.reconciled_at? %>
    <p class="muted">Session reconciled at <%= l(@session.reconciled_at, format: :long) %>.</p>
  <% elsif Current.user.can?("reporting.reconcile_session", store: Current.store) %>
    <div class="page-actions">
      <%= link_to "Reconcile session now", session_reconciliation_path(@session), class: "button" %>
      <%= link_to "Review later", reconciliations_path, class: "button button-outline" %>
    </div>
  <% else %>
    <p class="muted">Reconciliation requires reporting.reconcile_session.</p>
  <% end %>
</section>


<div class="page-actions">
  <%= link_to "Back to register", register_path, class: "button button-outline" %>
  <%= link_to "Print", "#", onclick: "window.print(); return false;", class: "button" %>
</div>
