<% if @pos_transaction.open? %>
  <% refundable = @refundable_original_tenders || [] %>
  <% refundable_sv = refundable.select { |t| t.tender_type.tender_category == "stored_value" } %>
  <% refundable_cash = refundable.select { |t| t.tender_type.tender_category == "cash" } %>
  <% refundable_card = refundable.select { |t| t.tender_type.tender_category == "card" } %>
  <% card_types = @tender_types.select { |t| t.tender_category == "card" } %>
  <% void_confirm = @card_void_confirmation %>

  <% if void_confirm.present? %>
    <% void_type = @tender_types.find { |t| t.id == void_confirm["tender_type_id"] } %>
    <details class="pos-panel" open>
      <summary>Confirm external void (authorization not attachable)</summary>
      <p class="muted">
        <%= void_confirm["error"] %>
        Void the authorization on the terminal, then record it as voided so the reference is retained.
      </p>
      <%= form_with url: record_voided_pos_transaction_pos_tenders_path(@pos_transaction), method: :post, class: "form" do |form| %>
        <%= hidden_field_tag :tender_type_id, void_confirm["tender_type_id"] %>
        <%= hidden_field_tag :amount_cents, format("%.2f", void_confirm["amount_cents"].to_i / 100.0) %>
        <%= hidden_field_tag :authorization_code, void_confirm["authorization_code"] %>
        <%= hidden_field_tag :terminal_reference, void_confirm["terminal_reference"] %>
        <% if void_confirm["refund"] %>
          <%= hidden_field_tag :refund, "1" %>
        <% end %>
        <p>
          <%= void_type&.name || "Card" %> ·
          <%= number_to_currency(void_confirm["amount_cents"].to_i / 100.0) %>
          <% if void_confirm["authorization_code"].present? %>
            · <%= void_confirm["authorization_code"] %>
          <% end %>
          <% if void_confirm["terminal_reference"].present? %>
            · <%= void_confirm["terminal_reference"] %>
          <% end %>
        </p>
        <div class="field">
          <%= form.label :external_void_reference, "External void reference (optional)", class: "field-label" %>
          <%= form.text_field :external_void_reference, class: "input" %>
        </div>
        <div class="checkbox-group">
          <label>
            <%= check_box_tag :external_void_confirmed, "true", false %>
            External void confirmed
          </label>
        </div>
        <div class="form-actions">
          <%= form.submit "Record voided card tender", class: "button button-danger",
                data: { turbo_confirm: "Confirm the card was voided on the external terminal." } %>
        </div>
      <% end %>
    </details>
  <% end %>

  <details class="pos-panel" open>
    <summary>Cash tender</summary>
    <%= form_with url: pos_transaction_pos_tenders_path(@pos_transaction), method: :post, class: "form" do |form| %>
      <div class="field">
        <%= form.label :tender_type_id, "Tender type", class: "field-label" %>
        <%= form.collection_select :tender_type_id, @tender_types.where(tender_category: "cash"), :id, :name, {}, class: "input" %>
      </div>
      <%= render "shared/currency_field", name: "amount_tendered_cents", label: "Amount tendered",
            id: "cash_amount_tendered_cents", value_cents: [ @balance_due_cents, 0 ].max %>
      <div class="form-actions">
        <%= form.submit "Add cash tender", class: "button button-primary" %>
      </div>
    <% end %>
  </details>

  <% card_types.each do |card_type| %>
    <details class="pos-panel">
      <summary><%= card_type.name %></summary>
      <p class="muted">Confirm approval on the external terminal first; record the result here. Partial card tenders are allowed.</p>
      <%= form_with url: pos_transaction_pos_tenders_path(@pos_transaction), method: :post, class: "form" do |form| %>
        <%= hidden_field_tag :tender_type_id, card_type.id %>
        <%= render "shared/currency_field", name: "amount_cents", label: "Amount",
              id: "card_amount_cents_#{card_type.id}", value_cents: [ @balance_due_cents, 0 ].max %>
        <div class="field">
          <%= form.label :authorization_code, card_type.reference_1_label.presence || "Reference 1", class: "field-label" %>
          <%= form.text_field :authorization_code, class: "input",
                required: card_type.reference_1_requirement == "required" %>
        </div>
        <div class="field">
          <%= form.label :terminal_reference, card_type.reference_2_label.presence || "Reference 2", class: "field-label" %>
          <%= form.text_field :terminal_reference, class: "input",
                required: card_type.reference_2_requirement == "required" %>
        </div>
        <div class="form-actions">
          <%= form.submit "Add card tender", class: "button button-outline" %>
        </div>
      <% end %>
    </details>
  <% end %>

  <% if @tender_types.where(tender_category: "stored_value").exists? && Current.user.can?("stored_value.tender.redeem", store: Current.store) && @balance_due_cents.positive? %>
    <details class="pos-panel">
      <summary>Stored-value tender</summary>
      <%= form_with url: pos_transaction_pos_tenders_path(@pos_transaction), method: :post, class: "form" do |form| %>
        <div class="field">
          <%= form.label :tender_type_id, "Tender type", class: "field-label" %>
          <%= form.collection_select :tender_type_id, @tender_types.where(tender_category: "stored_value"), :id, :name, {}, class: "input" %>
        </div>
        <div class="field">
          <%= form.label :account_number, "Account number", class: "field-label" %>
          <%= form.text_field :account_number, class: "input", autocomplete: "off" %>
        </div>
        <%= render "shared/currency_field", name: "amount_cents", label: "Amount",
              id: "sv_tender_amount_cents", value_cents: [ @balance_due_cents, 0 ].max %>
        <div class="form-actions">
          <%= form.submit "Redeem stored value", class: "button button-outline" %>
        </div>
      <% end %>
    </details>
  <% end %>

  <% if @balance_due_cents.negative? && Current.user.can?("stored_value.tender.refund", store: Current.store) && @tender_types.where(tender_category: "stored_value").exists? %>
    <details class="pos-panel" open>
      <summary>Stored-value refund</summary>
      <p class="muted">
        Restore an original stored-value tender when one remains, or issue new store credit.
        Exception approval is required to skip a remaining original tender.
      </p>
      <%= form_with url: pos_transaction_pos_tenders_path(@pos_transaction), method: :post, class: "form" do |form| %>
        <%= hidden_field_tag :refund, "1" %>
        <div class="field">
          <%= form.label :tender_type_id, "Tender type", class: "field-label" %>
          <%= form.collection_select :tender_type_id, @tender_types.where(tender_category: "stored_value"), :id, :name, {}, class: "input" %>
        </div>
        <% if refundable_sv.any? %>
          <div class="field">
            <%= form.label :original_pos_tender_id, "Original stored-value tender", class: "field-label" %>
            <%= form.select :original_pos_tender_id,
                  refundable_sv.map { |t|
                    label = "#{t.stored_value_account&.account_number || t.id} — #{number_to_currency(t.remaining_refundable_cents / 100.0)} remaining"
                    [ label, t.id ]
                  },
                  { include_blank: "Issue new store credit instead…" },
                  class: "input" %>
          </div>
        <% end %>
        <div class="field">
          <%= check_box_tag :create_store_credit, "1", refundable_sv.empty?, id: "create_store_credit" %>
          <%= label_tag :create_store_credit, "Create new store-credit account (when not restoring an original)" %>
        </div>
        <div class="field">
          <%= form.label :account_number, "Existing store-credit account (optional)", class: "field-label" %>
          <%= form.text_field :account_number, class: "input", autocomplete: "off",
                placeholder: "Leave blank to create new store credit" %>
        </div>
        <%= render "shared/currency_field", name: "amount_cents", label: "Refund amount",
              id: "sv_refund_amount_cents", value_cents: -@balance_due_cents %>
        <%= render "pos_transactions/refund_exception_fields", form: form, prefix: "sv" %>
        <div class="form-actions">
          <%= form.submit "Record stored-value refund", class: "button button-outline" %>
        </div>
      <% end %>
    </details>
  <% end %>

  <% if @balance_due_cents.negative? && Current.user.can?("pos.tender.cash", store: Current.store) %>
    <details class="pos-panel" <%= "open" unless refundable_sv.any? %>>
      <summary>Cash refund</summary>
      <p class="muted">Link the original cash tender when restoring it. Exception approval is required for a non-original destination.</p>
      <%= form_with url: pos_transaction_pos_tenders_path(@pos_transaction), method: :post, class: "form" do |form| %>
        <%= hidden_field_tag :refund, "1" %>
        <div class="field">
          <%= form.label :tender_type_id, "Tender type", class: "field-label" %>
          <%= form.collection_select :tender_type_id, @tender_types.where(tender_category: "cash"), :id, :name, {}, class: "input" %>
        </div>
        <% if refundable_cash.any? %>
          <div class="field">
            <%= form.label :original_pos_tender_id, "Original cash tender", class: "field-label" %>
            <%= form.select :original_pos_tender_id,
                  refundable_cash.map { |t|
                    [ "Tender ##{t.id} — #{number_to_currency(t.remaining_refundable_cents / 100.0)} remaining", t.id ]
                  },
                  { include_blank: "Select original… (or exception below)" },
                  class: "input" %>
          </div>
        <% end %>
        <%= render "shared/currency_field", name: "amount_cents", label: "Refund amount",
              id: "refund_amount_cents", value_cents: -@balance_due_cents %>
        <%= render "pos_transactions/refund_exception_fields", form: form, prefix: "cash" %>
        <div class="form-actions">
          <%= form.submit "Add cash refund", class: "button button-outline" %>
        </div>
      <% end %>
    </details>
  <% end %>

  <% if @balance_due_cents.negative? && Current.user.can?("pos.tender.card_standalone", store: Current.store) && card_types.any? %>
    <% card_types.each do |card_type| %>
      <details class="pos-panel">
        <summary><%= card_type.name %> refund</summary>
        <p class="muted">
          Process the refund on the external terminal, then record the new authorization references here.
          Partial refunds are allowed within the remaining refund balance.
        </p>
        <% if refundable_card.any? %>
          <p class="muted">Original card tenders available for restoration:</p>
          <ul class="muted">
            <% refundable_card.each do |t| %>
              <li><%= pos_original_card_tender_option_label(t) %></li>
            <% end %>
          </ul>
        <% end %>
        <%= form_with url: pos_transaction_pos_tenders_path(@pos_transaction), method: :post, class: "form" do |form| %>
          <%= hidden_field_tag :refund, "1" %>
          <%= hidden_field_tag :tender_type_id, card_type.id %>
          <% if refundable_card.any? %>
            <div class="field">
              <%= form.label :original_pos_tender_id, "Original card tender", class: "field-label" %>
              <%= form.select :original_pos_tender_id,
                    refundable_card.map { |t| [ pos_original_card_tender_option_label(t), t.id ] },
                    { include_blank: "Select original… (or exception below)" },
                    class: "input" %>
            </div>
          <% end %>
          <%= render "shared/currency_field", name: "amount_cents", label: "Refund amount",
                id: "card_refund_amount_cents_#{card_type.id}",
                value_cents: -@balance_due_cents %>
          <div class="field">
            <%= form.label :authorization_code, card_type.reference_1_label.presence || "Reference 1", class: "field-label" %>
            <%= form.text_field :authorization_code, class: "input",
                  required: card_type.reference_1_requirement == "required" %>
          </div>
          <div class="field">
            <%= form.label :terminal_reference, card_type.reference_2_label.presence || "Reference 2", class: "field-label" %>
            <%= form.text_field :terminal_reference, class: "input",
                  required: card_type.reference_2_requirement == "required" %>
          </div>
          <%= render "pos_transactions/refund_exception_fields", form: form, prefix: "card_refund_#{card_type.id}" %>
          <div class="form-actions">
            <%= form.submit "Record card refund", class: "button button-outline" %>
          </div>
        <% end %>
      </details>
    <% end %>
  <% end %>
<% end %>
