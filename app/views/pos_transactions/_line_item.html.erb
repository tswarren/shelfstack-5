<tr class="<%= "pos-line-return" if line.return? %> <%= "pos-line-selected" if @selected_line_id == line.id %>">
  <td>
    <% if @pos_transaction.editable? %>
      <%= link_to "Select",
            pos_transaction_path(@pos_transaction, intent: @entry_intent, selected_line_id: line.id, focus_target: "line_actions"),
            class: "button button-small #{@selected_line_id == line.id ? 'button-primary' : 'button-outline'}",
            aria: { pressed: (@selected_line_id == line.id) } %>
    <% end %>
    <%= line.effective_description %>
    <% if line.return? %>
      <br><span class="muted">Return of line #<%= line.original_pos_line_item_id %> · <%= line.return_reason&.name %> · <%= line.return_disposition&.humanize %></span>
    <% end %>
    <% if line.inventory_unit.present? %>
      <br><span class="muted">Unit <%= line.inventory_unit.unit_identifier %></span>
    <% end %>
  </td>
  <td class="num"><%= line.quantity %></td>
  <td class="num"><%= pos_money(line.unit_price_cents) %></td>
  <td class="num"><%= pos_money(line.extended_price_cents) %></td>
  <td class="num"><%= pos_money(@line_discount_cents_by_id ? @line_discount_cents_by_id.fetch(line.id, 0) : line.discount_amount_cents) %></td>
  <td class="num"><%= pos_money(@line_tax_cents_by_id ? @line_tax_cents_by_id.fetch(line.id, 0) : line.tax_amount_cents) %></td>
  <td class="num"><%
    discount_cents = @line_discount_cents_by_id ? @line_discount_cents_by_id.fetch(line.id, 0) : line.discount_amount_cents.to_i
    tax_cents = @line_tax_cents_by_id ? @line_tax_cents_by_id.fetch(line.id, 0) : line.tax_amount_cents.to_i
  %><%= pos_money(line.extended_price_cents - discount_cents + tax_cents) %></td>
  <td>
    <% if @pos_transaction.editable? && Current.user.can?("pos.line.remove", store: Current.store) %>
      <%= button_to "Remove", pos_transaction_pos_line_item_path(@pos_transaction, line), method: :delete,
            class: "button button-small button-danger",
            params: { intent: @entry_intent, focus_target: "scan" } %>
    <% end %>
  </td>
</tr>
<% if @pos_transaction.editable? && line.sale? && line.line_kind != "stored_value" && line.tax_category_overridden? %>
  <tr class="pos-line-detail-row">
    <td colspan="8">
      <p class="muted">Tax category overridden from <%= line.original_tax_category&.name %> to <%= line.tax_category&.name %> — <%= line.tax_category_override_reason %></p>
    </td>
  </tr>
<% end %>
