<% if @pos_transaction.editable? %>
  <%
    preserve_scan = %w[failed ambiguous].include?(@scan_outcome.to_s)
    scan_value = preserve_scan ? @scan_query.to_s : nil
    intent = @entry_intent.presence || "sale"
  %>

  <% if intent == "sale" %>
    <section class="pos-panel" aria-label="Scan or search">
      <h2>Scan / search</h2>
      <%= form_with url: pos_transaction_pos_line_items_path(@pos_transaction), method: :post,
            class: "pos-inline-form",
            data: { "pos-register-target": "scanForm" } do |form| %>
        <%= hidden_field_tag :intent, intent %>
        <div class="field">
          <label class="field-label" for="scan_query">Scan or search</label>
          <%= form.text_field :query, id: "scan_query", placeholder: "ISBN / SKU / unit ID",
                autocomplete: "off", class: "input",
                value: scan_value,
                data: { "pos-register-target": "scanInput" } %>
        </div>
        <div class="field">
          <label class="field-label" for="scan_quantity">Qty</label>
          <%= form.number_field :quantity, id: "scan_quantity", value: 1, min: 1, class: "input input-qty" %>
        </div>
        <% if @fulfillable_customer_requests.present? %>
          <div class="field">
            <label class="field-label" for="scan_product_request_id">Customer request (optional)</label>
            <%= form.select :product_request_id,
                  @fulfillable_customer_requests.map { |request|
                    label = "##{request.id} — #{request.product.name}"
                    label += " / #{request.product_variant.name}" if request.product_variant
                    label += " (#{request.outstanding_quantity} outstanding)"
                    [ label, request.id ]
                  },
                  { include_blank: "None" },
                  id: "scan_product_request_id", class: "input" %>
          </div>
        <% end %>
        <%= form.submit "Add line", class: "button button-primary" %>
      <% end %>
      <%= render "scan_resolution" %>
    </section>
  <% elsif intent == "stored_value" %>
    <section class="pos-panel" aria-label="Gift card issue / reload">
      <h2>Gift card issue / reload</h2>
      <%= form_with url: pos_transaction_pos_line_items_path(@pos_transaction), method: :post, class: "form" do |form| %>
        <%= hidden_field_tag :kind, "stored_value" %>
        <%= hidden_field_tag :intent, "sale" %>
        <div class="field">
          <%= form.label :stored_value_operation, "Operation", class: "field-label" %>
          <%= form.select :stored_value_operation, [ [ "Issue", "issue" ], [ "Reload", "reload" ] ], {}, class: "input" %>
        </div>
        <%= render "shared/currency_field", name: "amount_cents", label: "Amount", id: "sv_amount_cents_intent" %>
        <div class="field">
          <%= form.label :account_number, "Existing account number", class: "field-label" %>
          <%= form.text_field :account_number, class: "input", autocomplete: "off" %>
        </div>
        <div class="field">
          <label class="field-label">
            <%= check_box_tag :create_account, "1" %>
            Create new gift-card account
          </label>
        </div>
        <div class="form-actions">
          <%= form.submit "Add gift-card line", class: "button button-outline" %>
        </div>
      <% end %>
    </section>
  <% elsif intent == "open_ring" %>
    <section class="pos-panel" aria-label="Open-ring line">
      <h2>Open-ring line</h2>
      <%= form_with url: pos_transaction_pos_line_items_path(@pos_transaction), method: :post, class: "form" do |form| %>
        <%= hidden_field_tag :kind, "open_ring" %>
        <%= hidden_field_tag :intent, "sale" %>
        <div class="field">
          <%= form.label :department_id, "Department", class: "field-label" %>
          <%= form.select :department_id,
                @departments.map { |d| [ hierarchy_path_label(d), d.id ] },
                {}, class: "input" %>
        </div>
        <%= render "shared/currency_field", name: "unit_price_cents", label: "Price", id: "open_ring_unit_price_cents_intent" %>
        <div class="field">
          <%= form.label :quantity, class: "field-label" %>
          <%= form.number_field :quantity, value: 1, min: 1, class: "input input-qty" %>
        </div>
        <div class="field">
          <%= form.label :description, "Description (optional)", class: "field-label" %>
          <%= form.text_field :description, placeholder: "Blank uses department name", class: "input" %>
        </div>
        <div class="form-actions">
          <%= form.submit "Add open-ring line", class: "button button-outline" %>
        </div>
      <% end %>
    </section>
  <% elsif intent == "return" && Current.user.can?("pos.return.create", store: Current.store) %>
    <section class="pos-panel" aria-label="Linked return">
      <h2>Linked return</h2>
      <%= render "return_lookup_body" %>
    </section>
  <% end %>
<% end %>
