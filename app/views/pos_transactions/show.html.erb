<% if @pos_transaction.completed? %>
  <% content_for :head do %>
    <meta name="turbo-cache-control" content="no-cache">
  <% end %>
  <div class="pos-workspace pos-completed-workspace" data-controller="pos-register"
       data-pos-register-completed-value="true">
    <span hidden data-pos-register-target="announce">
      <%= flash[:notice].presence || "Transaction complete. Receipt #{@pos_transaction.receipt_number}." %>
    </span>
    <div class="pos-live-region" role="status" aria-live="polite" data-pos-register-target="liveRegion"></div>

    <section class="pos-panel pos-completed-summary" aria-label="Completed transaction">
      <p class="muted">State: Receipt</p>
      <h2>Transaction complete</h2>
      <p class="pos-receipt-number">Receipt <strong><%= @pos_transaction.receipt_number %></strong></p>
      <p class="muted">Completed <%= formatted_datetime(@pos_transaction.completed_at, format: :short) %></p>

      <dl class="definition-grid pos-totals">
        <div class="definition-item"><dt>Final total</dt><dd class="pos-balance"><%= pos_money(@net_total_cents) %></dd></div>
        <div class="definition-item"><dt>Tendered</dt><dd><%= pos_money(@tendered_total_cents) %></dd></div>
        <% if @change_due_cents.to_i.positive? %>
          <div class="definition-item">
            <dt>Change due</dt>
            <dd class="pos-balance pos-change"><%= pos_money(@change_due_cents) %></dd>
          </div>
        <% end %>
      </dl>

      <%= render "void_required_tenders" %>

      <% if @pos_tenders.any? %>
        <h3>Tenders</h3>
        <ul class="pos-tender-summary">
          <% @pos_tenders.each do |tender| %>
            <li>
              <%= tender.tender_type.name %> · <%= tender.direction.humanize %> ·
              <%= pos_money(tender.amount_cents) %>
              <% if tender.change_due_cents.to_i.positive? %>
                <span class="muted">(change <%= pos_money(tender.change_due_cents) %>)</span>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% end %>

      <div class="form-actions">
        <%= link_to "Next transaction", register_path, class: "button button-primary button-large",
              data: { "pos-register-target": "backToRegister" },
              autofocus: true %>
        <% if @pos_transaction.reverses_pos_transaction_id.blank? && !@pos_transaction.post_void_transaction && !@pos_transaction.void_required_tenders? %>
          <%= link_to "Post-void", post_void_form_pos_transaction_path(@pos_transaction),
                class: "button button-ghost button-large" %>
        <% end %>
      </div>
      <p class="field-hint">Press Enter to start the next transaction from Ready.</p>
    </section>

    <details class="pos-panel">
      <summary>Transaction detail</summary>
      <%= render "line_items" %>
      <%= render "totals" %>
    </details>
  </div>
<% else %>
  <% tender_mode = @presentation_state == "tender" || @presentation_state == "recovery" %>
  <% content_for :head do %>
    <meta name="turbo-cache-control" content="no-cache">
  <% end %>
  <%= render "session_context" %>
  <%= render "transaction_status" %>
  <%= render "recall_summary" %>

  <div class="pos-workspace" data-controller="pos-register"
       data-pos-register-scan-outcome-value="<%= @scan_outcome %>"
       data-pos-register-focus-target-value="<%= @focus_target %>">
    <span hidden data-pos-register-target="announce"><%= flash[:notice].presence || flash[:alert] %></span>
    <div class="pos-live-region" role="status" aria-live="polite" data-pos-register-target="liveRegion"></div>

    <div class="pos-workspace-banner">
      <p class="muted" role="status">
        State: <strong><%= @workspace.label %></strong>
        · Intent: <strong><%= (@entry_intent || "sale").humanize %></strong>
      </p>

      <% if @presentation_state == "recovery" || @completion_outcome == "failed" %>
        <%= render "recovery_panel" %>
      <% end %>
    </div>

    <section class="pos-sale-panel" aria-label="Sale" <% if tender_mode %>hidden<% end %>>
      <%= render "entry_intents" %>
      <%= render "scan_form" %>
      <%= render "line_items" %>
      <%= render "selected_line_actions" %>
      <%= render "secondary_actions" %>
    </section>

    <aside class="pos-payment-panel" aria-label="Payment">
      <%= render "totals" %>
      <%= render "readiness_summary" %>
      <%= render "primary_cta" %>
      <%= render "void_required_tenders" %>
      <% if tender_mode || !@pos_transaction.editable? || @pos_tenders.any? %>
        <%= render "tenders" %>
        <%= render "tender_entry" %>
      <% else %>
        <details class="pos-panel">
          <summary>Tender entry</summary>
          <%= render "tenders" %>
          <%= render "tender_entry" %>
        </details>
      <% end %>
      <%= render "transaction_actions" %>
      <% if tender_mode && @pos_transaction.editable? %>
        <p>
          <%= link_to "Return to editing",
                pos_transaction_path(@pos_transaction, intent: @entry_intent, selected_line_id: @selected_line_id),
                class: "button button-ghost button-small",
                data: (@pos_transaction.unresolved_tenders? ? { turbo_confirm: "Leave tender with unresolved payment activity?" } : {}) %>
        </p>
      <% end %>
    </aside>
  </div>

  <p><%= link_to "Back to register", register_path, class: "button button-ghost button-small" %></p>
<% end %>
