<% content_for :title, "Transaction #{@pos_transaction.public_id}" %>

<h1>Transaction</h1>
<p class="muted">
  Public ID <strong><%= @pos_transaction.public_id %></strong> ·
  Status <strong><%= @pos_transaction.status %></strong> ·
  Store <strong><%= Current.store.name %></strong> ·
  Cashier <strong><%= @pos_transaction.cashier_user.username %></strong>
  <% if @pos_transaction.tax_exempt? %>
    · <strong>Tax exempt</strong>
  <% end %>
</p>

<% if flash[:alert].present? %>
  <div class="ss-alert ss-alert-danger"><p><%= flash[:alert] %></p></div>
<% end %>
<% if flash[:notice].present? %>
  <div class="ss-alert ss-alert-info"><p><%= flash[:notice] %></p></div>
<% end %>

<% if @pos_transaction.completed? %>
  <div class="ss-alert ss-alert-info">
    <p>
      <strong>Receipt <%= @pos_transaction.receipt_number %></strong> ·
      completed <%= @pos_transaction.completed_at&.strftime("%Y-%m-%d %H:%M") %> ·
      net <%= pos_money(@pos_transaction.net_total_cents) %>
    </p>
  </div>
<% elsif @pos_transaction.open? && !@pos_transaction.editable? %>
  <div class="ss-alert ss-alert-warning">
    <p>Commercial fields (lines, prices, discounts, tax category, exemptions) are locked while a Tender is pending or authorized. Remove or void the Tender below to resume editing.</p>
  </div>
<% end %>

<% if @pos_transaction.editable? %>
  <div class="pos-panel">
    <h2>Scan / search</h2>
    <%= form_with url: pos_transaction_pos_line_items_path(@pos_transaction), method: :post do |form| %>
      <%= form.text_field :query, placeholder: "Scan or search ISBN/SKU", autofocus: true, autocomplete: "off" %>
      <%= form.number_field :quantity, value: 1, min: 1, style: "width:5em" %>
      <%= form.submit "Add line", class: "button button-primary" %>
    <% end %>
  </div>

  <div class="pos-panel">
    <h2>Open-ring</h2>
    <%= form_with url: pos_transaction_pos_line_items_path(@pos_transaction), method: :post do |form| %>
      <%= hidden_field_tag :kind, "open_ring" %>
      <%= form.label :department_id, "Department" %>
      <%= form.collection_select :department_id, @departments, :id, :name %>
      <%= form.label :description, "Description (optional)" %>
      <%= form.text_field :description, placeholder: "Blank uses department name" %>
      <%= form.label :unit_price_cents, "Price (cents)" %>
      <%= form.number_field :unit_price_cents, min: 0 %>
      <%= form.label :quantity %>
      <%= form.number_field :quantity, value: 1, min: 1, style: "width:5em" %>
      <%= form.submit "Add open-ring line", class: "button button-outline" %>
    <% end %>
  </div>
<% end %>

<h2>Lines</h2>
<table>
  <thead>
    <tr>
      <th>Kind</th><th>Description</th><th>Qty</th><th>Price</th><th>Extended</th><th>Discount</th><th>Tax</th><th>Net</th><th></th>
    </tr>
  </thead>
  <tbody>
    <% @pos_line_items.each do |line| %>
      <tr>
        <td><%= line.line_kind %></td>
        <td><%= line.effective_description %></td>
        <td>
          <% if @pos_transaction.editable? %>
            <%= form_with url: pos_transaction_pos_line_item_path(@pos_transaction, line), method: :patch do |form| %>
              <%= form.number_field :quantity, value: line.quantity, min: 1, style: "width:4em" %>
              <%= form.submit "Update", class: "button button-small button-outline" %>
            <% end %>
          <% else %>
            <%= line.quantity %>
          <% end %>
        </td>
        <td><%= pos_money(line.unit_price_cents) %></td>
        <td><%= pos_money(line.extended_price_cents) %></td>
        <td><%= pos_money(line.discount_amount_cents) %></td>
        <td><%= pos_money(line.tax_amount_cents) %></td>
        <td><%= pos_money(line.extended_price_cents - line.discount_amount_cents + line.tax_amount_cents) %></td>
        <td>
          <% if @pos_transaction.editable? && Current.user.can?("pos.line.remove", store: Current.store) %>
            <%= button_to "Remove", pos_transaction_pos_line_item_path(@pos_transaction, line), method: :delete, class: "button button-small button-danger" %>
          <% end %>
        </td>
      </tr>
      <% if @pos_transaction.editable? %>
        <tr>
          <td></td>
          <td colspan="8">
            <% if line.tax_category_overridden? %>
              <p class="muted">Tax category overridden from <%= line.original_tax_category&.name %> to <%= line.tax_category&.name %> — <%= line.tax_category_override_reason %></p>
            <% end %>
            <details>
              <summary>Line actions</summary>

              <% if line.line_kind == "product" %>
                <%= form_with url: override_price_pos_transaction_pos_line_item_path(@pos_transaction, line), method: :patch, class: "pos-inline-form" do |form| %>
                  <%= form.label :requested_unit_price_cents, "Override price (cents)" %>
                  <%= form.number_field :requested_unit_price_cents, min: 0, style: "width:6em" %>
                  <%= form.text_field :reason, placeholder: "Reason" %>
                  <%= form.text_field :approver_username, placeholder: "Approver username (if needed)" %>
                  <%= form.password_field :approver_pin, placeholder: "Approver PIN" %>
                  <%= form.submit "Override price", class: "button button-small button-outline" %>
                <% end %>
              <% end %>

              <%= form_with url: override_tax_category_pos_transaction_pos_line_item_path(@pos_transaction, line), method: :patch, class: "pos-inline-form" do |form| %>
                <%= form.label :tax_category_id, "Override tax category" %>
                <%= form.collection_select :tax_category_id, @tax_categories, :id, :name, { selected: line.tax_category_id } %>
                <%= form.text_field :reason, placeholder: "Reason (required)" %>
                <%= form.text_field :approver_username, placeholder: "Approver username (if needed)" %>
                <%= form.password_field :approver_pin, placeholder: "Approver PIN" %>
                <%= form.submit "Override tax category", class: "button button-small button-outline" %>
              <% end %>

              <%= form_with url: pos_transaction_pos_discounts_path(@pos_transaction), method: :post, class: "pos-inline-form" do |form| %>
                <%= hidden_field_tag :scope, "line" %>
                <%= hidden_field_tag :pos_line_item_id, line.id %>
                <%= form.label :method, "Line discount" %>
                <%= form.select :method, [ [ "Percentage", "percentage" ], [ "Fixed amount", "fixed_amount" ], [ "Fixed price", "fixed_price" ] ] %>
                <%= form.number_field :rate_bps, placeholder: "Rate (bps)", min: 0, max: 10_000, style: "width:5em" %>
                <%= form.number_field :amount_cents, placeholder: "Amount/target price (cents)", min: 0, style: "width:8em" %>
                <%= form.collection_select :discount_reason_id, @discount_reasons, :id, :name, { include_blank: "No reason" } %>
                <%= form.text_field :reason, placeholder: "Reason" %>
                <%= form.text_field :approver_username, placeholder: "Approver username (if needed)" %>
                <%= form.password_field :approver_pin, placeholder: "Approver PIN" %>
                <%= form.submit "Apply line discount", class: "button button-small button-outline" %>
              <% end %>
            </details>
          </td>
        </tr>
      <% end %>
    <% end %>
  </tbody>
</table>

<div class="pos-totals">
  <p><strong>Subtotal:</strong> <%= pos_money(@subtotal_cents) %></p>
  <p><strong>Discount:</strong> <%= pos_money(@discount_total_cents) %></p>
  <p><strong>Tax:</strong> <%= pos_money(@tax_total_cents) %></p>
  <p><strong>Net total:</strong> <%= pos_money(@net_total_cents) %></p>
</div>

<h2>Tenders</h2>
<% if @pos_tenders.any? %>
  <table>
    <thead>
      <tr><th>Type</th><th>Direction</th><th>Status</th><th>Amount</th><th>Reference</th><th></th></tr>
    </thead>
    <tbody>
      <% @pos_tenders.each do |tender| %>
        <tr>
          <td><%= tender.tender_type.name %></td>
          <td><%= tender.direction %></td>
          <td><%= tender.status %></td>
          <td><%= pos_money(tender.amount_cents) %></td>
          <td><%= tender.authorization_code || tender.terminal_reference %></td>
          <td>
            <% if @pos_transaction.open? && tender.unresolved? %>
              <%= button_to "Remove", pos_transaction_pos_tender_path(@pos_transaction, tender), method: :delete, class: "button button-small button-danger" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="muted">No tenders recorded.</p>
<% end %>

<% if @pos_transaction.open? %>
  <p><strong>Balance due:</strong> <%= pos_money(@balance_due_cents) %></p>

  <div class="pos-panel">
    <h3>Cash tender</h3>
    <%= form_with url: pos_transaction_pos_tenders_path(@pos_transaction), method: :post, class: "pos-inline-form" do |form| %>
      <%= form.label :tender_type_id, "Tender type" %>
      <%= form.collection_select :tender_type_id, @tender_types.where(tender_category: "cash"), :id, :name %>
      <%= form.label :amount_tendered_cents, "Amount tendered (cents)" %>
      <%= form.number_field :amount_tendered_cents, min: 1, value: @balance_due_cents, style: "width:8em" %>
      <%= form.submit "Add cash tender", class: "button button-outline" %>
    <% end %>
  </div>

  <div class="pos-panel">
    <h3>Standalone card tender</h3>
    <p class="muted">Confirm approval on the external terminal first; record the result here.</p>
    <%= form_with url: pos_transaction_pos_tenders_path(@pos_transaction), method: :post, class: "pos-inline-form" do |form| %>
      <%= form.label :tender_type_id, "Tender type" %>
      <%= form.collection_select :tender_type_id, @tender_types.where(tender_category: "card"), :id, :name %>
      <%= form.label :amount_cents, "Amount (cents)" %>
      <%= form.number_field :amount_cents, min: 1, value: @balance_due_cents, style: "width:8em" %>
      <%= form.label :authorization_code, "Authorization code" %>
      <%= form.text_field :authorization_code %>
      <%= form.label :terminal_reference, "Terminal reference (optional)" %>
      <%= form.text_field :terminal_reference %>
      <%= form.submit "Add card tender", class: "button button-outline" %>
    <% end %>
  </div>

  <% if Current.user.can?("pos.transaction.complete", store: Current.store) %>
    <%= form_with url: complete_pos_transaction_path(@pos_transaction), method: :post do |form| %>
      <%= hidden_field_tag :completion_idempotency_key, @completion_idempotency_key %>
      <%= form.submit "Complete transaction", class: "button button-primary" %>
    <% end %>
  <% end %>
<% end %>

<% if @removed_line_items.any? %>
  <h2>Removed lines</h2>
  <ul>
    <% @removed_line_items.each do |line| %>
      <li><%= line.effective_description %> — removed <%= line.removed_at&.strftime("%Y-%m-%d %H:%M") %></li>
    <% end %>
  </ul>
<% end %>

<% if @pos_transaction.editable? %>
  <div class="pos-panel">
    <h2>Transaction-wide discount</h2>
    <%= form_with url: pos_transaction_pos_discounts_path(@pos_transaction), method: :post do |form| %>
      <%= hidden_field_tag :scope, "transaction" %>
      <%= form.label :method, "Method" %>
      <%= form.select :method, [ [ "Percentage", "percentage" ], [ "Fixed amount", "fixed_amount" ] ] %>
      <%= form.number_field :rate_bps, placeholder: "Rate (bps)", min: 0, max: 10_000, style: "width:5em" %>
      <%= form.number_field :amount_cents, placeholder: "Amount (cents)", min: 0, style: "width:8em" %>
      <%= form.collection_select :discount_reason_id, @discount_reasons, :id, :name, { include_blank: "No reason" } %>
      <%= form.text_field :reason, placeholder: "Reason" %>
      <%= form.text_field :approver_username, placeholder: "Approver username (if needed)" %>
      <%= form.password_field :approver_pin, placeholder: "Approver PIN" %>
      <%= form.submit "Apply discount", class: "button button-outline" %>
    <% end %>
  </div>

  <% unless @pos_transaction.tax_exempt? %>
    <div class="pos-panel">
      <h2>Tax exemption</h2>
      <%= form_with url: pos_transaction_pos_tax_exemption_path(@pos_transaction), method: :post do |form| %>
        <%= form.label :exemption_type, "Exemption type" %>
        <%= form.text_field :exemption_type, placeholder: "e.g. resale_certificate" %>
        <%= form.text_field :notes, placeholder: "Notes" %>
        <%= form.text_field :approver_username, placeholder: "Approver username (if needed)" %>
        <%= form.password_field :approver_pin, placeholder: "Approver PIN" %>
        <%= form.submit "Apply whole-transaction exemption", class: "button button-outline" %>
      <% end %>
    </div>
  <% else %>
    <p class="muted">
      Exempt: <%= @pos_transaction.pos_tax_exemptions.first&.exemption_type %>
    </p>
  <% end %>
<% end %>

<% if @pos_transaction.open? %>
  <div class="pos-actions">
    <% if @pos_transaction.editable? && Current.user.can?("pos.transaction.suspend", store: Current.store) %>
      <%= button_to "Suspend", suspend_pos_transaction_path(@pos_transaction), class: "button button-outline" %>
    <% end %>
    <% if Current.user.can?("pos.transaction.cancel", store: Current.store) %>
      <%= button_to "Cancel", cancel_pos_transaction_path(@pos_transaction), class: "button button-danger",
            form: { data: { turbo_confirm: "Cancel this transaction?" } } %>
    <% end %>
  </div>
<% elsif @pos_transaction.suspended? && Current.user.can?("pos.transaction.recall", store: Current.store) %>
  <%= button_to "Recall", recall_pos_transaction_path(@pos_transaction), class: "button button-primary" %>
<% end %>

<p><%= link_to "Back to register", register_path %></p>
