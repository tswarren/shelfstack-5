<% content_for :title, "Transaction #{@pos_transaction.public_id}" %>

<%= render "session_context" %>
<%= render "transaction_status" %>
<%= render "recall_summary" %>

<div class="pos-workspace" data-controller="pos-register"
     data-pos-register-scan-outcome-value="<%= @scan_outcome %>">
  <span hidden data-pos-register-target="announce"><%= flash[:notice].presence || flash[:alert] %></span>
  <div class="pos-live-region" role="status" aria-live="polite" data-pos-register-target="liveRegion"></div>

  <section class="pos-sale-panel" aria-label="Sale">
    <%= render "scan_form" %>
    <%= render "line_items" %>
    <%= render "secondary_actions" %>
  </section>

  <aside class="pos-payment-panel" aria-label="Payment">
    <%= render "totals" %>
    <%= render "tenders" %>
    <%= render "tender_entry" %>
    <%= render "transaction_actions" %>
  </aside>
</div>

<p><%= link_to "Back to register", register_path, class: "button button-ghost button-small" %></p>
