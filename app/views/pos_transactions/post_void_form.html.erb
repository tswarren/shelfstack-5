<section class="pos-panel" aria-label="Post-void">
  <h2>Post-void receipt <%= @pos_transaction.receipt_number %></h2>
  <p class="muted">Creates a new reversing transaction. The original receipt is not changed.</p>

  <% if @eligibility.blockers.any? %>
    <div class="flash flash-alert" role="alert">
      <p>This transaction cannot be post-voided:</p>
      <ul>
        <% @eligibility.blockers.each do |blocker| %>
          <li><%= blocker %></li>
        <% end %>
      </ul>
    </div>
    <p><%= link_to "Back", pos_transaction_path(@pos_transaction), class: "button button-ghost" %></p>
  <% elsif @post_void_preparation.blank? %>
    <%= form_with url: prepare_post_void_pos_transaction_path(@pos_transaction), method: :post, class: "form-stack" do %>
      <div class="field">
        <label class="field-label" for="post_void_reason">Reason</label>
        <textarea name="post_void_reason" id="post_void_reason" class="input" required rows="3"></textarea>
      </div>

      <%= render "shared/approval_fields", prefix: "post_void" %>
      <p class="field-hint">Leave approver username blank to self-approve (requires pos.post_void.approve_self).</p>

      <div class="form-actions">
        <%= submit_tag "Approve post-void plan", class: "button" %>
        <%= link_to "Cancel", pos_transaction_path(@pos_transaction), class: "button button-ghost" %>
      </div>
    <% end %>
  <% else %>
    <p class="muted">
      Plan approved for reason: <%= @post_void_preparation.reason %>.
      Approval is already bound — do not re-enter a PIN to submit.
    </p>

    <% if @card_tenders.any? %>
      <fieldset class="form-stack">
        <legend>External card void / refund confirmation</legend>
        <p class="muted">
          Process each card on the terminal, then record the confirmation
          <strong>before</strong> submitting the post-void. Recorded confirmations are kept
          even if post-void later fails.
        </p>
        <% @card_tenders.each do |tender| %>
          <% prep = @card_preparations[tender.id] %>
          <div class="form-grid">
            <p><%= tender.tender_type.name %> · <%= pos_money(tender.amount_cents) %></p>
            <% if prep.blank? %>
              <%= button_to "Prepare card confirmation",
                    prepare_post_void_card_pos_transaction_path(@pos_transaction),
                    method: :post,
                    params: { original_pos_tender_id: tender.id },
                    class: "button button-outline" %>
            <% elsif prep.prepared? %>
              <p class="muted">Preparation ready — use the terminal, then record:</p>
              <%= form_with url: record_post_void_card_pos_transaction_path(@pos_transaction), method: :post, class: "form" do %>
                <%= hidden_field_tag :preparation_id, prep.id %>
                <div class="field">
                  <label class="field-label" for="card_auth_<%= tender.id %>">Authorization code</label>
                  <input type="text" class="input" name="authorization_code" id="card_auth_<%= tender.id %>">
                </div>
                <div class="field">
                  <label class="field-label" for="card_term_<%= tender.id %>">Terminal reference</label>
                  <input type="text" class="input" name="terminal_reference" id="card_term_<%= tender.id %>">
                </div>
                <div class="field">
                  <label class="field-label" for="card_void_<%= tender.id %>">External void reference</label>
                  <input type="text" class="input" name="external_void_reference" id="card_void_<%= tender.id %>">
                </div>
                <div class="form-actions">
                  <%= submit_tag "Record confirmation", class: "button button-outline" %>
                </div>
              <% end %>
              <%= button_to "Abandon preparation",
                    abandon_post_void_card_pos_transaction_path(@pos_transaction),
                    method: :post,
                    params: { preparation_id: prep.id },
                    class: "button button-ghost",
                    form: { data: { turbo_confirm: "Abandon only if the terminal was not used." } } %>
            <% else %>
              <p class="muted">
                Recorded
                <% if prep.authorization_code.present? %>· auth <%= prep.authorization_code %><% end %>
                <% if prep.external_void_reference.present? %>· void <%= prep.external_void_reference %><% end %>
              </p>
            <% end %>
          </div>
        <% end %>
      </fieldset>
    <% end %>

    <%= form_with url: post_void_pos_transaction_path(@pos_transaction), method: :post, class: "form-stack" do %>
      <input type="hidden" name="completion_idempotency_key" value="<%= SecureRandom.uuid %>">

      <div class="form-actions">
        <%= submit_tag "Post-void transaction", class: "button button-danger" %>
        <%= link_to "Cancel", pos_transaction_path(@pos_transaction), class: "button button-ghost" %>
      </div>
    <% end %>

    <%= button_to "Abandon post-void plan",
          abandon_post_void_pos_transaction_path(@pos_transaction),
          method: :post,
          class: "button button-ghost",
          form: { data: { turbo_confirm: "Abandon this approved plan? Recorded card confirmations block abandon." } } %>
  <% end %>
</section>
