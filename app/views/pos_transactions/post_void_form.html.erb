<section class="pos-panel" aria-label="Post-void">
  <h2>Post-void receipt <%= @pos_transaction.receipt_number %></h2>
  <p class="muted">Creates a new reversing transaction. The original receipt is not changed.</p>

  <% if @eligibility.blockers.any? %>
    <div class="flash flash-alert" role="alert">
      <p>This transaction cannot be post-voided:</p>
      <ul>
        <% @eligibility.blockers.each do |blocker| %>
          <li><%= blocker %></li>
        <% end %>
      </ul>
    </div>
    <p><%= link_to "Back", pos_transaction_path(@pos_transaction), class: "button button-ghost" %></p>
  <% elsif @post_void_approval.blank? %>
    <%= form_with url: approve_post_void_pos_transaction_path(@pos_transaction), method: :post, class: "form-stack" do %>
      <div class="field">
        <label class="field-label" for="post_void_reason">Reason</label>
        <textarea name="post_void_reason" id="post_void_reason" class="input" required rows="3"></textarea>
      </div>

      <%= render "shared/approval_fields", prefix: "post_void" %>
      <p class="field-hint">Leave approver username blank to self-approve (requires pos.post_void.approve_self).</p>

      <div class="form-actions">
        <%= submit_tag "Approve post-void", class: "button" %>
        <%= link_to "Cancel", pos_transaction_path(@pos_transaction), class: "button button-ghost" %>
      </div>
    <% end %>
  <% else %>
    <p class="muted">
      Approved for reason: <%= @post_void_approval[:reason] %>.
      Reverse card tenders on the terminal, enter confirmations below, then submit.
    </p>

    <%= form_with url: post_void_pos_transaction_path(@pos_transaction), method: :post, class: "form-stack" do %>
      <input type="hidden" name="completion_idempotency_key" value="<%= SecureRandom.uuid %>">

      <% if @card_tenders.any? %>
        <fieldset class="form-stack">
          <legend>External card void / refund confirmation</legend>
          <p class="muted">
            Confirm each original card tender was reversed on the terminal
            <strong>before</strong> submitting. Confirmations are audited even if post-void later fails.
          </p>
          <% @card_tenders.each do |tender| %>
            <div class="form-grid">
              <p>
                <%= tender.tender_type.name %> · <%= pos_money(tender.amount_cents) %>
                <% if tender.authorization_code.present? %>
                  <span class="muted">· <%= tender.authorization_code %></span>
                <% end %>
                <% if tender.terminal_reference.present? %>
                  <span class="muted">· <%= tender.terminal_reference %></span>
                <% end %>
              </p>
              <div class="checkbox-group">
                <label>
                  <input type="hidden" name="card_confirmations[<%= tender.id %>][external_void_confirmed]" value="0">
                  <input type="checkbox" name="card_confirmations[<%= tender.id %>][external_void_confirmed]"
                         value="1" id="card_confirmed_<%= tender.id %>" required>
                  I confirm this payment was manually reversed on the external terminal.
                </label>
              </div>
              <div class="field">
                <label class="field-label" for="card_void_<%= tender.id %>">External void reference (optional)</label>
                <input type="text" class="input"
                       name="card_confirmations[<%= tender.id %>][external_void_reference]"
                       id="card_void_<%= tender.id %>">
              </div>
              <div class="field">
                <label class="field-label" for="card_note_<%= tender.id %>">Confirmation note (optional)</label>
                <input type="text" class="input"
                       name="card_confirmations[<%= tender.id %>][confirmation_note]"
                       id="card_note_<%= tender.id %>">
              </div>
            </div>
          <% end %>
        </fieldset>
      <% end %>

      <div class="form-actions">
        <%= submit_tag "Post-void transaction", class: "button button-danger" %>
        <%= link_to "Cancel", pos_transaction_path(@pos_transaction), class: "button button-ghost" %>
      </div>
    <% end %>

    <%= button_to "Clear approval",
          clear_post_void_approval_pos_transaction_path(@pos_transaction),
          method: :post,
          class: "button button-ghost",
          form: { data: { turbo_confirm: "Clear this approval and start over?" } } %>
  <% end %>
</section>
