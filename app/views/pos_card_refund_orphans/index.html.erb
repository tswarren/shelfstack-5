<% content_for :title, "Unresolved card refund orphans" %>

<section class="page-header">
  <h1>Unresolved card refund orphans</h1>
  <p class="muted">
    External card refunds recorded when the return could not accept a tender (including
    after an abandoned preparation). Resolve each with an explicit outcome.
  </p>
</section>

<section class="panel" aria-labelledby="late-auth-heading">
  <h2 id="late-auth-heading">Record late authorization</h2>
  <p class="muted">
    Use when a terminal authorization arrives after the preparation was abandoned or the
    return was closed. Submit the preparation ID and authorization only — never appends a
    tender to completed or cancelled history.
  </p>
  <%= form_with url: record_authorization_pos_card_refund_orphans_path, method: :post, class: "form" do |form| %>
    <div class="field">
      <%= label_tag :preparation_id, "Preparation ID" %>
      <%= text_field_tag :preparation_id, nil, class: "input", required: true,
            placeholder: "UUID from the preparation", autocomplete: "off" %>
    </div>
    <div class="field">
      <%= label_tag :authorization_code, "Authorization code" %>
      <%= text_field_tag :authorization_code, nil, class: "input", required: true,
            autocomplete: "off" %>
    </div>
    <div class="field">
      <%= label_tag :terminal_reference, "Terminal reference (optional)" %>
      <%= text_field_tag :terminal_reference, nil, class: "input", autocomplete: "off" %>
    </div>
    <%= form.submit "Record authorization", class: "button" %>
  <% end %>
</section>

<% if @preparations.empty? %>
  <p class="muted">No unresolved orphan card refunds for this store.</p>
<% else %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Recorded</th>
        <th>Transaction</th>
        <th>Amount</th>
        <th>Auth</th>
        <th>Abandoned?</th>
        <th>Reasons</th>
        <th>Resolve</th>
      </tr>
    </thead>
    <tbody>
      <% @preparations.each do |prep| %>
        <tr>
          <td><%= formatted_datetime(prep.consumed_at, format: :short) %></td>
          <td><%= link_to prep.pos_transaction.public_id, pos_transaction_path(prep.pos_transaction) %></td>
          <td><%= number_to_currency(prep.amount_cents / 100.0) %></td>
          <td><%= prep.authorization_code %></td>
          <td><%= prep.abandoned_at.present? ? "Yes" : "—" %></td>
          <td><%= Array(prep.reconciliation_reasons).join("; ") %></td>
          <td>
            <%= form_with url: resolve_pos_card_refund_orphan_path(prep), method: :post, class: "form" do |form| %>
              <div class="field">
                <%= select_tag :resolution_kind,
                      options_for_select([
                        [ "External void confirmed", "external_void_confirmed" ],
                        [ "Accepted financial exception", "accepted_financial_exception" ]
                      ]),
                      class: "input" %>
              </div>
              <div class="field">
                <%= text_field_tag :reason, nil, class: "input", required: true, placeholder: "Reason" %>
              </div>
              <div class="field">
                <%= text_field_tag :external_void_reference, nil, class: "input", placeholder: "Void reference" %>
              </div>
              <div class="field">
                <%= text_field_tag :exception_approver_username, nil, class: "input",
                      placeholder: "Approver username (exception)" %>
              </div>
              <div class="field">
                <%= password_field_tag :exception_approver_pin, nil, class: "input",
                      placeholder: "Approver PIN", autocomplete: "off" %>
              </div>
              <%= form.submit "Resolve", class: "button button-outline button-small" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<section class="panel" aria-labelledby="post-void-card-heading">
  <h2 id="post-void-card-heading">Recorded post-void card confirmations</h2>
  <p class="muted">
    External card confirmations recorded for post-void that have not yet been consumed.
    Retry post-void from the original receipt; these facts survive a failed post-void attempt.
  </p>
  <% if @post_void_card_preparations.blank? %>
    <p class="muted">No unresolved recorded post-void card confirmations.</p>
  <% else %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Recorded</th>
          <th>Original receipt</th>
          <th>Amount</th>
          <th>Auth / void ref</th>
        </tr>
      </thead>
      <tbody>
        <% @post_void_card_preparations.each do |prep| %>
          <tr>
            <td><%= formatted_datetime(prep.authorized_at, format: :short) %></td>
            <td>
              <%= link_to prep.original_pos_transaction.receipt_number.presence || prep.original_pos_transaction.public_id,
                    post_void_form_pos_transaction_path(prep.original_pos_transaction) %>
            </td>
            <td><%= number_to_currency(prep.amount_cents / 100.0) %></td>
            <td>
              <%= prep.authorization_code %>
              <% if prep.external_void_reference.present? %>
                · <%= prep.external_void_reference %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>
