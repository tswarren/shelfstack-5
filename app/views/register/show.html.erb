<% content_for :title, "Register" %>

<h1>Register</h1>
<p class="muted">
  <strong><%= Current.store.name %></strong> ·
  Signed in as <strong><%= Current.user.username %></strong>
</p>

<% if flash[:alert].present? %>
  <div class="ss-alert ss-alert-danger"><p><%= flash[:alert] %></p></div>
<% end %>
<% if flash[:notice].present? %>
  <div class="ss-alert ss-alert-info"><p><%= flash[:notice] %></p></div>
<% end %>

<% if @business_day.blank? %>
  <div class="ss-alert ss-alert-info">
    <p>No business day is open for this store.</p>
  </div>
  <% if Current.user.can?("pos.business_day.open", store: Current.store) %>
    <%= link_to "Open business day", new_business_day_path, class: "button button-primary" %>
  <% end %>
<% else %>
  <p>
    Business day open since <%= @business_day.opened_at.strftime("%Y-%m-%d %H:%M") %>
    (reporting date <%= @business_day.reporting_date %>).
    <% if Current.user.can?("pos.business_day.close", store: Current.store) %>
      <%= button_to "Close business day", close_business_day_path(@business_day), class: "button button-small button-outline" %>
    <% end %>
  </p>

  <% if @open_session.blank? %>
    <div class="ss-alert ss-alert-info">
      <p>You have no open POS session.</p>
    </div>
    <% if Current.user.can?("pos.session.open", store: Current.store) %>
      <%= link_to "Open session", new_pos_session_path(business_day_id: @business_day.id), class: "button button-primary" %>
    <% end %>
  <% else %>
    <p>
      Session open on device <strong><%= @open_session.pos_device.name %></strong>
      <% if @open_session.cash_drawer.present? %>
        / drawer <strong><%= @open_session.cash_drawer.name %></strong>
      <% end %>.
      <% if Current.user.can?("pos.session.close", store: Current.store) %>
        <% if @open_session.cash_enabled? %>
          <%= link_to "Close session", close_form_pos_session_path(@open_session), class: "button button-small button-outline" %>
        <% else %>
          <%= button_to "Close session", close_pos_session_path(@open_session), class: "button button-small button-outline" %>
        <% end %>
      <% end %>
    </p>

    <% if @open_transaction.present? %>
      <p><%= link_to "Continue current transaction", pos_transaction_path(@open_transaction), class: "button button-primary" %></p>
    <% elsif Current.user.can?("pos.transaction.open", store: Current.store) %>
      <%= button_to "New sale", pos_transactions_path, class: "button button-primary" %>
    <% end %>

    <% if Current.user.can?("pos.cash_movement.create", store: Current.store) %>
      <div class="pos-panel">
        <h2>Cash movement</h2>
        <% if @open_session.pos_cash_movements.any? %>
          <table>
            <thead>
              <tr><th>Type</th><th>Direction</th><th>Amount</th><th>Reference</th></tr>
            </thead>
            <tbody>
              <% @open_session.pos_cash_movements.includes(:cash_movement_type).order(:id).each do |movement| %>
                <tr>
                  <td><%= movement.cash_movement_type.name %></td>
                  <td><%= movement.cash_movement_type.direction.humanize %></td>
                  <td><%= pos_money(movement.amount_cents) %></td>
                  <td><%= movement.reference.presence || "—" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% end %>
        <%= form_with url: pos_session_pos_cash_movements_path(@open_session), method: :post, class: "pos-inline-form" do |form| %>
          <%= form.label :cash_movement_type_id, "Type" %>
          <%= form.collection_select :cash_movement_type_id, @cash_movement_types, :id, :name %>
          <%= form.label :amount_cents, "Amount (cents)" %>
          <%= form.number_field :amount_cents, min: 1, style: "width:8em", required: true %>
          <%= form.text_field :reason, placeholder: "Reason" %>
          <%= form.text_field :reference, placeholder: "Reference (required for paid in/out and safe drop)" %>
          <%= form.text_field :approver_username, placeholder: "Approver username (if needed)" %>
          <%= form.password_field :approver_pin, placeholder: "Approver PIN" %>
          <%= form.submit "Record cash movement", class: "button button-outline" %>
        <% end %>
        <p class="muted">
          Additional float needs only amount.
          Paid in, paid out, and safe drop require a reference.
          Paid in/out also require approval when the amount exceeds your paid-out authority.
        </p>
      </div>
    <% end %>

    <h2>Suspended transactions</h2>
    <% if @suspended_transactions.empty? %>
      <p class="muted">None.</p>
    <% else %>
      <table>
        <thead>
          <tr><th>Public ID</th><th>Suspended at</th><th></th></tr>
        </thead>
        <tbody>
          <% @suspended_transactions.each do |transaction| %>
            <tr>
              <td><%= transaction.public_id %></td>
              <td><%= transaction.suspended_at&.strftime("%Y-%m-%d %H:%M") %></td>
              <td>
                <% if Current.user.can?("pos.transaction.recall", store: Current.store) %>
                  <%= button_to "Recall", recall_pos_transaction_path(transaction), class: "button button-small button-outline" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  <% end %>
<% end %>

<p><%= link_to "Home", root_path %></p>
