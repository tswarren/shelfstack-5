<% content_for :title, "Register" %>

<%= render "shared/page_header", title: "Register",
      subtitle: "#{Current.store.name} · Signed in as #{Current.user.username}" %>

<%#
  One dominant primary action based on register state. Secondary operational
  controls (close day/session, cash movements, recalls) stay below.
%>
<section class="card workspace-card workspace-primary" aria-label="Next action"
         data-controller="pos-register"
         data-pos-register-scan-outcome-value="<%= @scan_outcome %>">
  <span hidden data-pos-register-target="announce"><%= flash[:notice].presence || flash[:alert] %></span>
  <div class="pos-live-region" role="status" aria-live="polite" data-pos-register-target="liveRegion"></div>

  <% if @business_day.blank? %>
    <h2>Open a business day</h2>
    <p class="muted">No business day is open for this store.</p>
    <% if Current.user.can?("pos.business_day.open", store: Current.store) %>
      <div class="action-group">
        <%= link_to "Open business day", new_business_day_path, class: "button button-primary button-large" %>
      </div>
    <% end %>
  <% elsif @open_session.blank? %>
    <h2>Open a session</h2>
    <p class="muted">
      Business day open since <strong><%= formatted_datetime(@business_day.opened_at, format: :short) %></strong>
      · reporting date <%= @business_day.reporting_date %>
    </p>
    <% if Current.user.can?("pos.session.open", store: Current.store) %>
      <div class="action-group">
        <%= link_to "Open session", new_pos_session_path(business_day_id: @business_day.id), class: "button button-primary button-large" %>
      </div>
    <% end %>
  <% elsif @open_transaction.present? %>
    <h2>Resume transaction</h2>
    <p class="muted">A transaction is in progress.</p>
    <div class="action-group">
      <%= link_to "Resume transaction", pos_transaction_path(@open_transaction), class: "button button-primary button-large" %>
    </div>
  <% elsif Current.user.can?("pos.transaction.open", store: Current.store) %>
    <h2>Register ready</h2>
    <p class="muted">Scan merchandise to start, or open an empty transaction.</p>

    <% if @scan_outcome == "ambiguous" %>
      <p class="pos-readiness-warning" role="status">
        Multiple matches for <strong><%= @scan_query %></strong>. Open a transaction to resolve candidates.
      </p>
      <div class="action-group">
        <%= button_to "Open transaction to resolve", pos_transactions_path,
              params: { query: @scan_query, quantity: @scan_quantity },
              class: "button button-primary button-large" %>
      </div>
    <% end %>

    <%= form_with url: register_scan_to_start_path, method: :post, class: "pos-inline-form",
          data: { "pos-register-target": "scanForm" } do |form| %>
      <div class="field">
        <label class="field-label" for="ready_scan_query">Scan or search</label>
        <%= form.text_field :query, id: "ready_scan_query", name: "query",
              placeholder: "ISBN / SKU / unit ID",
              autocomplete: "off", class: "input",
              value: @scan_query,
              data: { "pos-register-target": "scanInput" } %>
      </div>
      <div class="field">
        <label class="field-label" for="ready_scan_quantity">Qty</label>
        <%= number_field_tag :quantity, @scan_quantity || 1, id: "ready_scan_quantity", min: 1, class: "input input-qty" %>
      </div>
      <%= form.submit "Scan to start", class: "button button-primary button-large" %>
    <% end %>

    <div class="action-group" style="margin-top: 1rem;">
      <%= button_to "New transaction", pos_transactions_path, class: "button button-outline button-large" %>
    </div>

    <details class="pos-panel" style="margin-top: 1rem;">
      <summary>Receipt lookup</summary>
      <%= form_with url: register_lookup_receipt_path, method: :post, class: "form" do |form| %>
        <div class="field">
          <%= form.label :receipt_number, "Receipt number", class: "field-label" %>
          <%= text_field_tag :receipt_number, nil, class: "input", autocomplete: "off" %>
        </div>
        <div class="form-actions">
          <%= form.submit "Look up receipt", class: "button button-outline" %>
        </div>
      <% end %>
    </details>
  <% else %>
    <h2>Register ready</h2>
    <p class="muted">Session is open. You do not have permission to start a transaction.</p>
  <% end %>
</section>

<details class="pos-panel">
  <summary>Day and session details</summary>
  <div class="workspace-landing">
    <section class="card workspace-card" aria-label="Business day">
      <h2>Business day</h2>
      <% if @business_day.blank? %>
        <p class="muted">No business day is open.</p>
      <% else %>
        <p>
          Open since <strong><%= formatted_datetime(@business_day.opened_at, format: :short) %></strong>
          <br><span class="muted">Reporting date <%= @business_day.reporting_date %></span>
        </p>
        <% if Current.user.can?("pos.business_day.close", store: Current.store) %>
          <div class="action-group">
            <%= button_to "Close business day", close_business_day_path(@business_day), class: "button button-small button-outline" %>
          </div>
        <% end %>
      <% end %>
    </section>

    <% if @business_day.present? %>
      <section class="card workspace-card" aria-label="POS session">
        <h2>Session</h2>
        <% if @open_session.blank? %>
          <p class="muted">No open POS session.</p>
        <% else %>
          <p>
            Device <strong><%= @open_session.pos_device.name %></strong>
            <% if @open_session.cash_drawer.present? %>
              <br>Drawer <strong><%= @open_session.cash_drawer.name %></strong>
            <% else %>
              <br><span class="muted">Card-only (no drawer)</span>
            <% end %>
          </p>
          <% if Current.user.can?("pos.session.close", store: Current.store) %>
            <div class="action-group">
              <% if @open_session.cash_enabled? %>
                <%= link_to "Close session", close_form_pos_session_path(@open_session), class: "button button-small button-outline" %>
              <% else %>
                <%= button_to "Close session", close_pos_session_path(@open_session), class: "button button-small button-outline" %>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </section>
    <% end %>
  </div>
</details>

<% if @open_session.present? && Current.user.can?("pos.cash_movement.create", store: Current.store) %>
  <details class="pos-panel">
    <summary>Cash movements</summary>
    <% if @open_session.pos_cash_movements.any? %>
      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th scope="col">Type</th>
              <th scope="col">Direction</th>
              <th scope="col" class="num">Amount</th>
              <th scope="col">Reference</th>
            </tr>
          </thead>
          <tbody>
            <% @open_session.pos_cash_movements.includes(:cash_movement_type).order(:id).each do |movement| %>
              <tr>
                <td><%= movement.cash_movement_type.name %></td>
                <td><%= movement.cash_movement_type.direction.humanize %></td>
                <td class="num"><%= pos_money(movement.amount_cents) %></td>
                <td><%= movement.reference.presence || "—" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
    <%= form_with url: pos_session_pos_cash_movements_path(@open_session), method: :post, class: "form" do |form| %>
      <div class="field">
        <%= form.label :cash_movement_type_id, "Type", class: "field-label" %>
        <%= form.collection_select :cash_movement_type_id, @cash_movement_types, :id, :name, {}, class: "input" %>
      </div>
      <%= render "shared/currency_field", name: "amount_cents", label: "Amount",
            id: "cash_movement_amount_cents", required: true %>
      <div class="field">
        <%= form.label :reason, class: "field-label" %>
        <%= form.text_field :reason, placeholder: "Reason", class: "input" %>
      </div>
      <div class="field">
        <%= form.label :reference, class: "field-label" %>
        <%= form.text_field :reference, placeholder: "Reference (required for paid in/out and safe drop)", class: "input" %>
      </div>
      <%= render "shared/approval_fields", prefix: "cash_movement" %>
      <div class="form-actions">
        <%= form.submit "Record cash movement", class: "button button-outline" %>
      </div>
    <% end %>
  </details>
<% end %>

<% if @open_session.present? %>
  <details class="pos-panel" <%= "open" if @suspended_transactions.any? %>>
    <summary>Suspended transactions (<%= @suspended_transactions.size %>)</summary>
    <% if @suspended_transactions.empty? %>
      <p class="muted">None.</p>
    <% else %>
      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th scope="col">Public ID</th>
              <th scope="col">Suspended at</th>
              <th scope="col"><span class="sr-only">Actions</span></th>
            </tr>
          </thead>
          <tbody>
            <% @suspended_transactions.each do |transaction| %>
              <tr>
                <td><%= link_to transaction.public_id, pos_transaction_path(transaction) %></td>
                <td><%= formatted_datetime(transaction.suspended_at, format: :short) %></td>
                <td>
                  <% if Current.user.can?("pos.transaction.recall", store: Current.store) %>
                    <%= button_to "Recall", recall_pos_transaction_path(transaction),
                          class: "button button-small button-outline",
                          form: { data: {
                            turbo_confirm: (@open_transaction.present? ?
                              "You have an open transaction. Suspend or complete it before recalling another?" :
                              "Recall this suspended transaction? This replaces Ready with that sale.")
                          } } %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </details>
<% end %>
