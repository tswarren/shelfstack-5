<h1>Administrative audit</h1>
<table>
  <thead>
    <tr><th>When</th><th>Actor</th><th>Action</th><th>Subject</th></tr>
  </thead>
  <tbody>
    <% @events.each do |event| %>
      <tr>
        <td><%= event.created_at %></td>
        <td><%= event.actor_user.username %></td>
        <td><%= event.action %></td>
        <td><%= event.subject_type %> #<%= event.subject_id %></td>
      </tr>
    <% end %>
  </tbody>
</table>
<p><%= link_to "Home", root_path %></p>
