<h1>New inventory unit</h1>

<%= form_with url: inventory_units_path, method: :post do %>
  <div>
    <label for="inventory_unit_product_variant_id">Variant</label>
    <select name="inventory_unit[product_variant_id]" id="inventory_unit_product_variant_id">
      <% @variants.each do |variant| %>
        <option value="<%= variant.id %>" <%= "selected" if @inventory_unit.product_variant_id == variant.id %>>
          <%= variant.sku %> — <%= variant.name %>
        </option>
      <% end %>
    </select>
  </div>
  <div>
    <label for="inventory_unit_acquisition_cost_cents">Acquisition cost (cents)</label>
    <input type="number" name="inventory_unit[acquisition_cost_cents]" id="inventory_unit_acquisition_cost_cents"
           value="<%= @inventory_unit.acquisition_cost_cents %>">
  </div>
  <div>
    <label for="inventory_unit_unit_price_cents">Unit price override (cents)</label>
    <input type="number" name="inventory_unit[unit_price_cents]" id="inventory_unit_unit_price_cents"
           value="<%= @inventory_unit.unit_price_cents %>">
  </div>
  <div>
    <label for="inventory_unit_product_condition_id">Condition</label>
    <select name="inventory_unit[product_condition_id]" id="inventory_unit_product_condition_id">
      <option value=""></option>
      <% @product_conditions.each do |condition| %>
        <option value="<%= condition.id %>" <%= "selected" if @inventory_unit.product_condition_id == condition.id %>>
          <%= condition.name %>
        </option>
      <% end %>
    </select>
  </div>
  <div>
    <label for="inventory_unit_acquisition_source_type">Acquisition source</label>
    <select name="inventory_unit[acquisition_source_type]" id="inventory_unit_acquisition_source_type">
      <option value=""></option>
      <% InventoryUnit::ACQUISITION_SOURCE_TYPES.each do |source_type| %>
        <option value="<%= source_type %>" <%= "selected" if @inventory_unit.acquisition_source_type == source_type %>>
          <%= source_type.humanize %>
        </option>
      <% end %>
    </select>
  </div>
  <div>
    <label for="inventory_unit_description">Description</label>
    <input type="text" name="inventory_unit[description]" id="inventory_unit_description"
           value="<%= @inventory_unit.description %>">
  </div>
  <div>
    <label for="inventory_unit_internal_notes">Internal notes</label>
    <input type="text" name="inventory_unit[internal_notes]" id="inventory_unit_internal_notes"
           value="<%= @inventory_unit.internal_notes %>">
  </div>
  <%= submit_tag "Create unit" %>
<% end %>

<p><%= link_to "Cancel", inventory_units_path %></p>
