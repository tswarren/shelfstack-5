<h1>Unit <%= @inventory_unit.unit_identifier %></h1>
<ul>
  <li>Variant: <%= @inventory_unit.product_variant.sku %> — <%= @inventory_unit.product_variant.name %></li>
  <li>Status: <%= @inventory_unit.status %></li>
  <li>Condition: <%= @inventory_unit.product_condition&.name || "(none)" %></li>
  <li>Acquisition cost: <%= @inventory_unit.acquisition_cost_cents.nil? ? "—" : inventory_money(@inventory_unit.acquisition_cost_cents) %></li>
  <li>Unit price override: <%= @inventory_unit.unit_price_cents.nil? ? "—" : inventory_money(@inventory_unit.unit_price_cents) %></li>
  <li>Acquisition source: <%= @inventory_unit.acquisition_source_type.presence || "(none)" %></li>
  <li>Acquired at: <%= @inventory_unit.acquired_at %></li>
  <li>Description: <%= @inventory_unit.description.presence || "(none)" %></li>
  <li>Internal notes: <%= @inventory_unit.internal_notes.presence || "(none)" %></li>
  <% if @inventory_unit.sold? %>
    <li>Sold via line: <%= link_to @inventory_unit.sold_pos_line_item.pos_transaction.public_id, pos_transaction_path(@inventory_unit.sold_pos_line_item.pos_transaction) %></li>
    <li>Sold at: <%= @inventory_unit.sold_at %></li>
  <% end %>
</ul>
<p><%= link_to "Inventory units", inventory_units_path %></p>
